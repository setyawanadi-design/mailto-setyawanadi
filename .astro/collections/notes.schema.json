{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "from": {
      "type": "string"
    },
    "fromEmail": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "preview": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "pinned": {
      "default": false,
      "type": "boolean"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "attachments": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "size": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "url",
          "size"
        ],
        "additionalProperties": false
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "from",
    "fromEmail",
    "date",
    "preview",
    "pinned",
    "tags",
    "attachments"
  ],
  "additionalProperties": false
}