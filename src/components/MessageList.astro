---
interface MessageEntry {
  slug: string;
  data: {
    title: string;
    from: string;
    fromEmail: string;
    date: Date;
    preview: string;
    pinned?: boolean;
    tags?: string[];
  };
}

interface Props {
  items: MessageEntry[];
  activeSlug?: string;
  folderName: string;
  folderLabel: string;
  basePath: string;
}

const { items, activeSlug, folderName, folderLabel, basePath } = Astro.props;

function formatDate(date: Date): string {
  const now = new Date();
  const diff = now.getTime() - date.getTime();
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));

  if (days === 0) {
    return date.toLocaleTimeString("en-US", {
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    });
  }
  if (days < 7) {
    return date.toLocaleDateString("en-US", { weekday: "short" });
  }
  return date.toLocaleDateString("en-US", {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
  });
}

const sortedItems = [...items].sort((a, b) => {
  // pinned first, then by date desc
  if (a.data.pinned && !b.data.pinned) return -1;
  if (!a.data.pinned && b.data.pinned) return 1;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<section class="msg-list" id="message-list">
  <!-- List header -->
  <div class="msg-list__header">
    <div class="msg-list__header-left">
      <h2 class="msg-list__title">{folderLabel}</h2>
      <span class="msg-list__count">{items.length} Messages</span>
    </div>
    <div class="msg-list__header-actions">
      <button
        class="msg-list__sort-btn"
        aria-label="Sort messages"
        title="Sort"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="16" y2="12"></line>
          <line x1="4" y1="18" x2="12" y2="18"></line>
        </svg>
      </button>
      <button class="msg-list__view-btn" aria-label="Toggle view" title="View">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <rect x="3" y="3" width="7" height="7"></rect>
          <rect x="14" y="3" width="7" height="7"></rect>
          <rect x="3" y="14" width="7" height="7"></rect>
          <rect x="14" y="14" width="7" height="7"></rect>
        </svg>
      </button>
    </div>
  </div>

  <!-- Message items -->
  <div class="msg-list__items">
    {
      sortedItems.length === 0 && (
        <div class="msg-list__empty">
          <svg
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
            stroke-linecap="round"
            opacity="0.3"
          >
            <polyline points="22 12 16 12 14 15 10 15 8 12 2 12" />
            <path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z" />
          </svg>
          <p>No messages in {folderLabel}</p>
        </div>
      )
    }

    {
      sortedItems.map((item) => (
        <a
          href={`${basePath}/${item.slug}`}
          class:list={[
            "msg-item",
            {
              "msg-item--active": activeSlug === item.slug,
              "msg-item--pinned": item.data.pinned,
            },
          ]}
          data-slug={item.slug}
        >
          {item.data.pinned && (
            <span class="msg-item__pin" title="Pinned">
              <svg
                width="10"
                height="10"
                viewBox="0 0 24 24"
                fill="currentColor"
                stroke="currentColor"
                stroke-width="1"
              >
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
            </span>
          )}
          <div class="msg-item__top">
            <span class="msg-item__subject">{item.data.title}</span>
            <span class="msg-item__date">
              {formatDate(new Date(item.data.date))}
            </span>
          </div>
          {item.data.tags && item.data.tags.length > 0 && (
            <div class="msg-item__tags">
              {item.data.tags.map((tag: string) => (
                <span class="msg-item__tag">{tag}</span>
              ))}
            </div>
          )}
          <p class="msg-item__preview">{item.data.preview}</p>
        </a>
      ))
    }
  </div>
</section>

<style>
  .msg-list {
    width: var(--list-width);
    min-width: var(--list-width);
    height: 100%;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border-right: 1px solid #dbeafe;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .msg-list__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md) var(--spacing-lg);
    border-bottom: 1px solid var(--border-subtle);
    min-height: 44px;
  }

  .msg-list__header-left {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-sm);
  }

  .msg-list__title {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text-primary);
  }

  .msg-list__count {
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }

  .msg-list__header-actions {
    display: flex;
    gap: var(--spacing-xs);
  }

  .msg-list__sort-btn,
  .msg-list__view-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .msg-list__sort-btn:hover,
  .msg-list__view-btn:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }

  .msg-list__items {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
  }

  .msg-list__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    padding: var(--spacing-2xl);
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    height: 200px;
  }

  /* Message item */
  .msg-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--spacing-md) var(--spacing-lg);
    border-bottom: 1px solid #e0f2fe;
    cursor: pointer;
    transition: background 0.15s ease;
    text-decoration: none;
    position: relative;
  }

  .msg-item:hover {
    background: #eff6ff;
  }

  .msg-item--active {
    background: linear-gradient(180deg, #e0f2fe 0%, #bae6fd 100%) !important;
    border-left: 5px solid #00aaff;
    padding-left: calc(var(--spacing-lg) - 5px);
  }

  .msg-item--active:hover {
    background: linear-gradient(180deg, #e0f2fe 0%, #bae6fd 100%) !important;
  }

  .msg-item__pin {
    position: absolute;
    top: 6px;
    right: 8px;
    color: #0ea5e9;
    opacity: 0.7;
  }

  .msg-item__top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--spacing-sm);
    margin-bottom: 1px;
  }

  .msg-item__subject {
    font-size: var(--font-size-sm);
    font-weight: 700;
    color: #0f172a;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .msg-item__date {
    font-size: var(--font-size-xs);
    color: #64748b;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .msg-item__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .msg-item__tag {
    font-size: 10px;
    font-weight: 600;
    color: #3182ce;
    background: #eff6ff;
    padding: 1px 8px;
    border-radius: 999px;
    letter-spacing: 0.02em;
  }

  .msg-item__preview {
    font-size: var(--font-size-sm);
    color: #64748b;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.4;
    margin: 0;
  }

  /* ===== DARK MODE ===== */
  :global([data-theme="dark"]) .msg-list {
    background: rgba(30, 41, 59, 0.8);
    border-right-color: #334155;
  }

  :global([data-theme="dark"]) .msg-item {
    border-bottom-color: #334155;
  }

  :global([data-theme="dark"]) .msg-item:hover {
    background: rgba(56, 189, 248, 0.06);
  }

  :global([data-theme="dark"]) .msg-item--active {
    background: linear-gradient(180deg, rgba(56, 189, 248, 0.15) 0%, rgba(56, 189, 248, 0.08) 100%) !important;
    border-left-color: #38bdf8;
  }

  :global([data-theme="dark"]) .msg-item--active:hover {
    background: linear-gradient(180deg, rgba(56, 189, 248, 0.15) 0%, rgba(56, 189, 248, 0.08) 100%) !important;
  }

  :global([data-theme="dark"]) .msg-item__subject {
    color: #f1f5f9;
  }

  :global([data-theme="dark"]) .msg-item__date {
    color: #94a3b8;
  }

  :global([data-theme="dark"]) .msg-item__tag {
    color: #60a5fa;
    background: rgba(96, 165, 250, 0.1);
  }

  :global([data-theme="dark"]) .msg-item__preview {
    color: #94a3b8;
  }

  @media (max-width: 768px) {
    .msg-list {
      width: 100%;
      min-width: 100%;
      border-right: none;
    }
  }
</style>
