---
import FormModal from "./FormModal.astro";
import { FORMSPREE_URL } from "../lib/folders";

interface Attachment {
  name: string;
  url: string;
  size: string;
}

interface Props {
  title: string;
  to?: string;
  date: Date;
  attachments?: Attachment[];
  prevUrl?: string;
  nextUrl?: string;
  folderUrl?: string;
}

const {
  title,
  to = "visitor@visitor",
  date,
  attachments = [],
  prevUrl,
  nextUrl,
  folderUrl,
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  weekday: "short",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  hour: "2-digit",
  minute: "2-digit",
  hour12: false,
});
---

<article class="reading-pane" id="reading-pane">
  <!-- Action bar -->
  <header class="reading-pane__actions">
    <div class="reading-pane__action-btns">
      <!-- Back button (mobile only) -->
      {folderUrl && (
        <a href={folderUrl} class="action-btn action-btn--back" aria-label="Back to list">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 19l-7-7 7-7"></path>
          </svg>
          <span>Back</span>
        </a>
      )}
      <!-- Expand button -->
      <button class="action-btn action-btn--expand" id="expand-btn" title="Expand View" aria-label="Expand">
        <svg class="expand-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 3 21 3 21 9"></polyline>
          <polyline points="9 21 3 21 3 15"></polyline>
          <line x1="21" y1="3" x2="14" y2="10"></line>
          <line x1="3" y1="21" x2="10" y2="14"></line>
        </svg>
        <svg class="collapse-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="4 14 10 14 10 20"></polyline>
          <polyline points="20 10 14 10 14 4"></polyline>
          <line x1="14" y1="10" x2="21" y2="3"></line>
          <line x1="3" y1="21" x2="10" y2="14"></line>
        </svg>
        <span class="expand-label">Expand</span>
        <span class="collapse-label">Collapse</span>
        <span class="action-btn__kbd">E</span>
      </button>
      <button class="action-btn" id="reply-btn" title="Reply" aria-label="Reply">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 17 4 12 9 7"></polyline>
          <path d="M20 18v-2a4 4 0 0 0-4-4H4"></path>
        </svg>
        <span>Reply</span>
        <span class="action-btn__kbd">R</span>
      </button>
      <button class="action-btn forward-btn" title="Forward" aria-label="Forward" data-share-title={title}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 17 20 12 15 7"></polyline>
          <path d="M4 18v-2a4 4 0 0 1 4-4h12"></path>
        </svg>
        <span>Forward</span>
        <span class="action-btn__kbd">F</span>
      </button>
    </div>
    <div class="reading-pane__nav-btns">
      {prevUrl ? (
        <a href={prevUrl} class="action-btn action-btn--nav" aria-label="Previous">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 19l-7-7 7-7"></path>
          </svg>
          <span class="action-btn__kbd">K</span>
        </a>
      ) : (
        <span class="action-btn action-btn--nav action-btn--disabled" aria-label="Previous" aria-disabled="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 19l-7-7 7-7"></path>
          </svg>
        </span>
      )}
      {nextUrl ? (
        <a href={nextUrl} class="action-btn action-btn--nav" aria-label="Next">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 5l7 7-7 7"></path>
          </svg>
          <span class="action-btn__kbd">J</span>
        </a>
      ) : (
        <span class="action-btn action-btn--nav action-btn--disabled" aria-label="Next" aria-disabled="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 5l7 7-7 7"></path>
          </svg>
        </span>
      )}
    </div>
  </header>

  <!-- Scrollable content area -->
  <div class="reading-pane__body">
    <!-- Post meta -->
    <div class="reading-pane__post-meta">
      <h1 class="reading-pane__title">{title}</h1>
      <div class="reading-pane__sender-row">
        <div class="reading-pane__sender-left">
          <div class="reading-pane__avatar">
            S
          </div>
          <div>
            <p class="reading-pane__from-line">
              mailto.setyawanadi
            </p>
            <p class="reading-pane__to-line">To: {to}</p>
          </div>
        </div>
        <div class="reading-pane__date-block">
          <p>{formattedDate}</p>
        </div>
      </div>
    </div>

    <!-- Post body -->
    <div class="email-body">
      <slot />

      <!-- Auto-generated signature -->
      <div class="email-signature">
        <p class="email-signature__regards">Best regards,</p>
        <p class="email-signature__name">Adi Setyawan</p>
        <p class="email-signature__links">
          <span class="email-signature__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 6 10-6"/></svg></span>
          <a href="mailto:setyawanadi@hotmail.com">setyawanadi@hotmail.com</a>
          <span class="email-signature__sep">&middot;</span>
          <span class="email-signature__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span>
          <a href="https://setyawanadi.netlify.app">setyawanadi.netlify.app</a>
        </p>
        <a href="https://sveltiacms.app/en/" target="_blank" rel="noopener" class="email-signature__badge">SENT VIA SVELTIA</a>
      </div>
    </div>

    <!-- Attachments -->
    {
      attachments.length > 0 && (
        <div class="reading-pane__attachments">
          <div class="attachments__header">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48" />
            </svg>
            <span>
              {attachments.length} attachment{attachments.length > 1 ? "s" : ""}
            </span>
          </div>
          <div class="attachments__list">
            {attachments.map((att) => (
              <a href={att.url} class="attachment" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                </svg>
                <span class="attachment__name">{att.name}</span>
                <span class="attachment__size">{att.size}</span>
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>

  <!-- Reply Modal -->
  <FormModal
    id="reply"
    title="Reply"
    formAction={FORMSPREE_URL}
    subjectValue={`Re: ${title}`}
    subjectReadonly={true}
    submitLabel="Send Reply"
    successMessage="Your reply has been delivered successfully. Thank you for reaching out!"
  />
</article>

<script>
  // Back button slide-out — delegated, registered once
  if (!(window as any).__backSlideRegistered) {
    (window as any).__backSlideRegistered = true;
    let isSliding = false;
    document.addEventListener("click", async (e) => {
      const backBtn = (e.target as HTMLElement).closest(".action-btn--back") as HTMLAnchorElement | null;
      if (!backBtn || window.innerWidth > 768 || isSliding) return;
      e.preventDefault();
      e.stopPropagation();
      isSliding = true;
      const pane = document.getElementById("reading-pane");
      const href = backBtn.href;
      if (pane) {
        const anim = pane.animate(
          [{ transform: "translateX(0)" }, { transform: "translateX(100%)" }],
          { duration: 250, easing: "cubic-bezier(0.4, 0, 1, 1)" }
        );
        await anim.finished;
        pane.style.transform = "translateX(100%)";
      }
      isSliding = false;
      const { navigate } = await import("astro:transitions/client");
      navigate(href);
    }, true);
  }

  // Entrance animations — use astro:after-swap (fires immediately when new DOM is in place)
  document.addEventListener("astro:after-swap", () => {
    const readingPane = document.getElementById("reading-pane");
    const isMobile = window.innerWidth <= 768;
    const navDir = sessionStorage.getItem("nav-direction");

    // Mobile: slide in the whole pane only on first open (no nav direction)
    if (readingPane && isMobile && !navDir) {
      readingPane.animate(
        [{ transform: "translateX(100%)" }, { transform: "translateX(0)" }],
        { duration: 250, easing: "cubic-bezier(0, 0, 0.2, 1)" }
      );
    }

    // Slide in body content for prev/next navigation (both mobile and desktop)
    if (readingPane && navDir) {
      const paneBody = readingPane.querySelector(".reading-pane__body") as HTMLElement | null;
      if (paneBody) {
        const enterX = navDir === "prev" ? "-40%" : "40%";
        paneBody.animate(
          [{ transform: `translateX(${enterX})`, opacity: "0" }, { transform: "translateX(0)", opacity: "1" }],
          { duration: 250, easing: "cubic-bezier(0, 0, 0.2, 1)" }
        );
      }
    }

    // Clear nav direction after use
    if (navDir) sessionStorage.removeItem("nav-direction");
  });

  document.addEventListener("astro:page-load", () => {
    // Store direction when clicking prev/next arrows — let links navigate naturally (no interception)
    document.querySelectorAll(".action-btn--nav").forEach((btn) => {
      btn.addEventListener("click", () => {
        const label = btn.getAttribute("aria-label");
        if (label === "Previous") {
          sessionStorage.setItem("nav-direction", "prev");
        } else if (label === "Next") {
          sessionStorage.setItem("nav-direction", "next");
        }
      });
    });

    // Expand toggle — state lives on <html data-expanded> so it survives View Transitions
    const expandBtn = document.getElementById("expand-btn");
    if (expandBtn) {
      expandBtn.addEventListener("click", () => {
        const html = document.documentElement;
        const isExpanded = html.hasAttribute("data-expanded");
        if (isExpanded) {
          html.removeAttribute("data-expanded");
          sessionStorage.removeItem("expanded");
        } else {
          html.setAttribute("data-expanded", "");
          sessionStorage.setItem("expanded", "1");
        }
      });
    }

    // Reply button — delegates to FormModal
    const replyBtn = document.getElementById("reply-btn");
    replyBtn?.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent('form-modal:open:reply'));
    });

    // Forward button — native share on mobile, copy link on desktop
    const forwardBtn = document.querySelector(".forward-btn");
    forwardBtn?.addEventListener("click", async () => {
      const shareTitle = (forwardBtn as HTMLElement).dataset.shareTitle || '';
      const url = window.location.href;

      if (navigator.share) {
        try {
          await navigator.share({ title: shareTitle, url });
        } catch {
          // User cancelled
        }
      } else {
        try {
          await navigator.clipboard.writeText(url);
          const label = forwardBtn.querySelector("span");
          if (label) {
            const original = label.textContent;
            label.textContent = "Link copied!";
            setTimeout(() => { label.textContent = original; }, 2000);
          }
        } catch {
          // Clipboard not available
        }
      }
    });
  });
</script>

<style>
  .reading-pane {
    flex: 1;
    height: 100%;
    background: var(--bg-detail);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ===== ACTION BAR ===== */
  .reading-pane__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-sm) var(--spacing-lg);
    border-bottom: 1px solid var(--border-detail);
    min-height: 56px;
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    flex-shrink: 0;
    z-index: 10;
  }

  .reading-pane__action-btns {
    display: flex;
    gap: var(--spacing-xs);
    align-items: center;
  }

  .reading-pane__nav-btns {
    display: flex;
    gap: var(--spacing-xs);
    align-items: center;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: 6px var(--spacing-md);
    border-radius: 999px;
    font-size: var(--font-size-xs);
    color: var(--text-action);
    font-weight: 600;
    border: 1px solid var(--border-subtle);
    background: var(--bg-action);
    cursor: pointer;
    transition:
      background var(--transition-fast),
      box-shadow var(--transition-fast);
    box-shadow: var(--shadow-sm);
  }

  .action-btn:hover {
    background: var(--bg-action-hover);
    box-shadow: var(--shadow-md);
  }

  .action-btn span {
    display: none;
  }

  /* Keyboard hint badges on nav buttons - always visible */
  .action-btn__kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    background: var(--bg-action);
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    font-family: var(--font-family);
    font-size: 11px;
    font-weight: 600;
    color: var(--text-action);
    margin-left: 6px;
    box-shadow: var(--shadow-sm);
  }

  @media (min-width: 1200px) {
    .action-btn span {
      display: inline;
    }

    /* Keep collapse label hidden by default even on wide screens */
    .action-btn .collapse-label {
      display: none;
    }

    :global(html[data-expanded]) .action-btn .collapse-label {
      display: inline;
    }

    :global(html[data-expanded]) .action-btn .expand-label {
      display: none;
    }
  }

  /* Hide keyboard hints on mobile */
  @media (max-width: 1199px) {
    .action-btn__kbd {
      display: none;
    }
  }

  .action-btn--nav {
    padding: 6px;
    text-decoration: none;
  }

  .action-btn--disabled {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
  }

  /* Expand/collapse icon + label visibility */
  .collapse-icon,
  .collapse-label {
    display: none;
  }

  :global(html[data-expanded]) .expand-icon,
  :global(html[data-expanded]) .expand-label {
    display: none;
  }

  :global(html[data-expanded]) .collapse-icon,
  :global(html[data-expanded]) .collapse-label {
    display: inline-block;
  }

  /* Expanded mode: center content with comfortable max-width */
  :global(html[data-expanded]) .reading-pane__body {
    max-width: 780px;
    margin: 0 auto;
    width: 100%;
  }

  /* ===== SCROLLABLE CONTENT AREA ===== */
  .reading-pane__body {
    flex: 1;
    overflow-y: auto;
    padding: var(--spacing-xl);
  }

  /* Ensure body clips animated content during slide transitions */
  .reading-pane__body {
    overflow-x: hidden;
  }

  /* ===== POST META ===== */
  .reading-pane__post-meta {
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-xl);
    border-bottom: 1px solid var(--border-detail);
  }

  .reading-pane__title {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
    margin-bottom: var(--spacing-lg);
  }

  .reading-pane__sender-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .reading-pane__sender-left {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .reading-pane__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bg-avatar);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--font-size-md);
    font-weight: 700;
    flex-shrink: 0;
  }

  .reading-pane__from-line {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text-primary);
  }

  .reading-pane__from-email {
    font-weight: 400;
    color: var(--text-muted);
  }

  .reading-pane__to-line {
    font-size: var(--font-size-xs);
    color: var(--text-detail-secondary);
  }

  .reading-pane__date-block {
    font-size: var(--font-size-xs);
    color: var(--text-detail-secondary);
    text-align: right;
  }

  /* ===== ATTACHMENTS ===== */
  .reading-pane__attachments {
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-lg);
    border-top: 1px dashed var(--border-detail);
  }

  .attachments__header {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: var(--font-size-xs);
    color: var(--text-detail-secondary);
    margin-bottom: var(--spacing-sm);
  }

  .attachments__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .attachment {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--bg-detail);
    border: 1px solid var(--border-detail);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    color: var(--text-primary);
    text-decoration: none;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .attachment:hover {
    background: var(--bg-action-hover);
    border-color: var(--border-separator);
  }

  .attachment__name {
    font-weight: 500;
  }

  .attachment__size {
    color: var(--text-detail-secondary);
    font-size: var(--font-size-xs);
  }

  /* ===== MOBILE: back button ===== */
  .action-btn--back {
    display: none;
    text-decoration: none;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .reading-pane {
      position: fixed;
      top: var(--toolbar-height);
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 80;
      height: auto;
    }

    .action-btn--back {
      display: flex;
    }

    .action-btn--back span {
      display: inline;
    }

    .action-btn--expand {
      display: none;
    }

  }
</style>
