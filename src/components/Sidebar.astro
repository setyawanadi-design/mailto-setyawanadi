---
interface Props {
  currentFolder: string;
}

const { currentFolder } = Astro.props;

function getIcon(name: string): string {
  const icons: Record<string, string> = {
    inbox:
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>',
    "file-text":
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
    send: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>',
    archive:
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>',
    "book-open":
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
    star: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
    list: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>',
  };
  return icons[name] || "";
}

const mainFolders = [
  { id: "inbox", label: "Inbox", icon: "inbox", badge: null as string | null },
  {
    id: "drafts",
    label: "Drafts",
    icon: "file-text",
    badge: null as string | null,
  },
  { id: "sent", label: "Sent", icon: "send", badge: null as string | null },
  {
    id: "archive",
    label: "Archive",
    icon: "archive",
    badge: null as string | null,
  },
  {
    id: "notes",
    label: "Notes",
    icon: "book-open",
    badge: null as string | null,
  },
  {
    id: "starred",
    label: "Starred",
    icon: "star",
    badge: null as string | null,
  },
];

const feedFolders = [
  {
    id: "logs",
    label: "Logs",
    icon: "list",
    badge: null as string | null,
  },
];
---

<aside class="sidebar" id="sidebar">
  <!-- Compose button -->
  <button type="button" class="sidebar__compose" id="compose-btn">
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M12 20h9"></path>
      <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
    </svg>
    <span>Send Message</span>
  </button>

  <!-- Account: setyawanadi -->
  <div class="sidebar__group-label">setyawanadi</div>

  <nav class="sidebar__nav">
    <ul class="sidebar__list">
      {
        mainFolders.map((folder) => (
          <li>
            <a
              href={`/${folder.id}`}
              class:list={[
                "sidebar__item",
                { "sidebar__item--active": currentFolder === folder.id },
              ]}
              data-folder={folder.id}
            >
              <span class="sidebar__icon" set:html={getIcon(folder.icon)} />
              <span class="sidebar__label">{folder.label}</span>
              {folder.badge && (
                <span class="sidebar__badge">{folder.badge}</span>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Feed -->
  <div class="sidebar__group-label">Feed</div>

  <nav class="sidebar__nav">
    <ul class="sidebar__list">
      {
        feedFolders.map((folder) => (
          <li>
            <a
              href={`/${folder.id}`}
              class:list={[
                "sidebar__item",
                { "sidebar__item--active": currentFolder === folder.id },
              ]}
              data-folder={folder.id}
            >
              <span class="sidebar__icon" set:html={getIcon(folder.icon)} />
              <span class="sidebar__label">{folder.label}</span>
              {folder.badge && (
                <span class="sidebar__badge">{folder.badge}</span>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>

<style>
  .sidebar {
    width: var(--sidebar-width);
    min-width: var(--sidebar-width);
    height: 100%;
    background: var(--bg-sidebar);
    border-right: 1px solid var(--border-subtle);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    overflow-x: hidden;
    padding: var(--spacing-sm) 0;
    user-select: none;
  }

  .sidebar__compose {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin: var(--spacing-xs) var(--spacing-sm) var(--spacing-lg);
    padding: 10px var(--spacing-md);
    background: var(--bg-compose-btn);
    color: #fff;
    border: 1px solid #1e70bf;
    border-radius: var(--radius-md);
    font-size: var(--font-size-base);
    font-weight: 500;
    cursor: pointer;
    transition:
      filter var(--transition-fast),
      transform var(--transition-fast);
    text-decoration: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4), 0 2px 4px rgba(0, 0, 0, 0.15);
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.2);
    font-family: inherit;
  }

  .sidebar__compose:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .sidebar__compose:active {
    transform: translateY(0);
    filter: brightness(0.95);
  }

  .sidebar__group-label {
    padding: var(--spacing-xs) var(--spacing-lg);
    margin-top: var(--spacing-sm);
    margin-bottom: 2px;
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .sidebar__nav {
    flex: none;
  }

  .sidebar__list {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .sidebar__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px var(--spacing-lg);
    font-size: var(--font-size-base);
    color: var(--text-secondary);
    border-left: 3px solid transparent;
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast);
    cursor: pointer;
    text-decoration: none;
  }

  .sidebar__item:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }

  .sidebar__item--active {
    background: #e0f2fe;
    color: var(--accent);
    border-left-color: var(--accent);
    font-weight: 500;
  }

  .sidebar__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .sidebar__item--active .sidebar__icon {
    opacity: 1;
    color: var(--accent);
  }

  .sidebar__label {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sidebar__badge {
    font-size: var(--font-size-xs);
    font-weight: 600;
    background: var(--badge-bg);
    color: var(--badge-text);
    padding: 1px 6px;
    border-radius: 10px;
    min-width: 18px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      top: var(--toolbar-height);
      left: 0;
      bottom: 0;
      z-index: 95;
      transform: translateX(-100%);
      transition: transform var(--transition-normal);
      box-shadow: var(--shadow-md);
      width: 240px;
      min-width: 240px;
    }

    .sidebar:global(.sidebar--open) {
      transform: translateX(0);
    }
  }
</style>
