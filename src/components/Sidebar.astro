---
interface Props {
  currentFolder: string;
}

const { currentFolder } = Astro.props;

function getIcon(name: string): string {
  const icons: Record<string, string> = {
    inbox:
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>',
    "file-text":
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
    send: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>',
    archive:
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>',
    "book-open":
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
    star: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
    list: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>',
  };
  return icons[name] || "";
}

const mainFolders = [
  { id: "inbox", label: "Inbox", icon: "inbox", badge: null as string | null },
  {
    id: "drafts",
    label: "Drafts",
    icon: "file-text",
    badge: null as string | null,
  },
  { id: "sent", label: "Sent", icon: "send", badge: null as string | null },
  {
    id: "archive",
    label: "Archive",
    icon: "archive",
    badge: null as string | null,
  },
  {
    id: "notes",
    label: "Notes",
    icon: "book-open",
    badge: null as string | null,
  },
  {
    id: "starred",
    label: "Starred",
    icon: "star",
    badge: null as string | null,
  },
];

const feedFolders = [
  {
    id: "logs",
    label: "Logs",
    icon: "list",
    badge: null as string | null,
  },
];
---

<aside class="sidebar" id="sidebar">
  <!-- Mobile header -->
  <div class="sidebar__header">
    <div class="sidebar__header-brand">
      <span class="sidebar__header-icon"><svg width="20" height="20" viewBox="0 0 48 48"><path fill="#45413c" d="M1.18 38.19a22.63 1.66 0 1 0 45.26 0a22.63 1.66 0 1 0-45.26 0" opacity=".15"/><path fill="#fff" d="M2.48 10.94h42.67v26.12H2.48Z"/><path fill="#f0f0f0" d="M44 34.37H3.58a1.1 1.1 0 0 1-1.1-1.1V36a1.1 1.1 0 0 0 1.1 1.1H44a1.1 1.1 0 0 0 1.1-1.1v-2.73a1.1 1.1 0 0 1-1.1 1.1"/><path fill="none" stroke="#45413c" stroke-linecap="round" stroke-linejoin="round" d="M2.48 10.94h42.67v26.12H2.48Z"/><path fill="none" stroke="#45413c" stroke-linecap="round" stroke-linejoin="round" d="m2.79 11.27l21.02 15.58l21.02-15.58M27.7 23.97l17.13 12.7m-42.04 0l17.13-12.7"/><path fill="#00b8f0" d="M14.16 23.75a9.84 9.84 0 1 0 19.68 0a9.84 9.84 0 1 0-19.68 0"/><path fill="#4acfff" d="M24 16.33A9.84 9.84 0 0 1 33.77 25a12 12 0 0 0 .07-1.21a9.84 9.84 0 0 0-19.68 0a12 12 0 0 0 .07 1.21A9.84 9.84 0 0 1 24 16.33"/><path fill="none" stroke="#45413c" stroke-linecap="round" stroke-linejoin="round" d="M14.16 23.75a9.84 9.84 0 1 0 19.68 0a9.84 9.84 0 1 0-19.68 0"/><path fill="#fff" d="M23.83 16.9a7.4 7.4 0 0 1 2.56.45a7.3 7.3 0 0 1 2.2 1.25a6.4 6.4 0 0 1 1.52 1.9a5 5 0 0 1 .58 2.38a4.06 4.06 0 0 1-.57 2.19a4.8 4.8 0 0 1-1.4 1.47a6.7 6.7 0 0 1-1.61.8a4.5 4.5 0 0 1-1.2.24c-.86 0-1.29-.3-1.29-.91a2.4 2.4 0 0 1-.86.66a2.45 2.45 0 0 1-1.09.25a2.3 2.3 0 0 1-1.09-.27a3 3 0 0 1-.88-.74a3.7 3.7 0 0 1-.58-1.05a3.5 3.5 0 0 1-.21-1.18a4.8 4.8 0 0 1 .26-1.54a4.3 4.3 0 0 1 .74-1.34a3.4 3.4 0 0 1 1.09-.92a3.2 3.2 0 0 1 1.48-.35a2.43 2.43 0 0 1 2.18 1.12v-.23c0-.59.34-.89 1-.89a1.25 1.25 0 0 1 .61.14a.42.42 0 0 1 .24.38a3 3 0 0 1-.07.6l-.74 3.38a2.6 2.6 0 0 0-.08.62c0 .26.15.39.43.39a1.37 1.37 0 0 0 .76-.31a2.56 2.56 0 0 0 .78-1a3.4 3.4 0 0 0 .41-1.52a3.8 3.8 0 0 0-.41-1.78a4.1 4.1 0 0 0-1.15-1.37a5.6 5.6 0 0 0-1.66-.86a6.5 6.5 0 0 0-2-.29a5.05 5.05 0 0 0-2 .4a5.1 5.1 0 0 0-1.66 1.1a5.5 5.5 0 0 0-1.11 1.66a5.1 5.1 0 0 0-.41 2a5.3 5.3 0 0 0 .4 2a5.25 5.25 0 0 0 2.78 2.78a5.2 5.2 0 0 0 2 .4a8.14 8.14 0 0 0 3.88-.88a6 6 0 0 0 .56-.43a1.4 1.4 0 0 1 .68-.37a.61.61 0 0 1 .69.69a1 1 0 0 1-.12.46a3.5 3.5 0 0 1-.38.55a5.66 5.66 0 0 1-2.35 1.29a11.2 11.2 0 0 1-3 .36a6.7 6.7 0 0 1-3.43-.92a6.86 6.86 0 0 1-2.49-2.5a6.85 6.85 0 0 1 2.49-9.36a6.6 6.6 0 0 1 3.52-.9m-.76 8.78a1.7 1.7 0 0 0 .93-.28a1.9 1.9 0 0 0 .67-.74a2.1 2.1 0 0 0 .24-1a1.72 1.72 0 0 0-.37-1.12a1.29 1.29 0 0 0-1-.46a1.44 1.44 0 0 0-.88.3a2.15 2.15 0 0 0-.64.76a2.06 2.06 0 0 0-.23.93a1.87 1.87 0 0 0 .35 1.12a1.11 1.11 0 0 0 .93.49"/></svg></span>
      <span>mailto.setyawanadi</span>
    </div>
    <button class="sidebar__close" id="sidebar-close" aria-label="Close sidebar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Compose button -->
  <button type="button" class="sidebar__compose" id="compose-btn">
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M12 20h9"></path>
      <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
    </svg>
    <span>Send Message</span>
  </button>

  <!-- Account: setyawanadi -->
  <div class="sidebar__group-label">setyawanadi</div>

  <nav class="sidebar__nav">
    <ul class="sidebar__list">
      {
        mainFolders.map((folder) => (
          <li>
            <a
              href={`/${folder.id}`}
              class:list={[
                "sidebar__item",
                { "sidebar__item--active": currentFolder === folder.id },
              ]}
              data-folder={folder.id}
              data-sidebar-link
            >
              <span class="sidebar__icon" set:html={getIcon(folder.icon)} />
              <span class="sidebar__label">{folder.label}</span>
              {folder.badge && (
                <span class="sidebar__badge">{folder.badge}</span>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Feed -->
  <div class="sidebar__group-label">Feed</div>

  <nav class="sidebar__nav">
    <ul class="sidebar__list">
      {
        feedFolders.map((folder) => (
          <li>
            <a
              href={`/${folder.id}`}
              class:list={[
                "sidebar__item",
                { "sidebar__item--active": currentFolder === folder.id },
              ]}
              data-folder={folder.id}
              data-sidebar-link
            >
              <span class="sidebar__icon" set:html={getIcon(folder.icon)} />
              <span class="sidebar__label">{folder.label}</span>
              {folder.badge && (
                <span class="sidebar__badge">{folder.badge}</span>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>

<style>
  .sidebar {
    width: var(--sidebar-width);
    min-width: var(--sidebar-width);
    height: 100%;
    background: var(--bg-sidebar);
    border-right: 1px solid var(--border-subtle);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    overflow-x: hidden;
    padding: var(--spacing-sm) 0;
    user-select: none;
  }

  /* Mobile header: hidden on desktop */
  .sidebar__header {
    display: none;
  }

  .sidebar__header-brand {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .sidebar__header-icon {
    display: flex;
    align-items: center;
    color: var(--text-primary);
  }

  .sidebar__header-brand span {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text-primary);
  }

  .sidebar__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .sidebar__close:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }

  .sidebar__compose {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin: var(--spacing-xs) var(--spacing-sm) var(--spacing-lg);
    padding: 10px var(--spacing-md);
    background: var(--bg-compose-btn);
    color: #fff;
    border: 1px solid var(--accent-hover);
    border-radius: var(--radius-md);
    font-size: var(--font-size-base);
    font-weight: 500;
    cursor: pointer;
    transition:
      filter var(--transition-fast),
      transform var(--transition-fast);
    text-decoration: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4), 0 2px 4px rgba(0, 0, 0, 0.15);
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.2);
    font-family: inherit;
  }

  .sidebar__compose:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .sidebar__compose:active {
    transform: translateY(0);
    filter: brightness(0.95);
  }

  .sidebar__group-label {
    padding: var(--spacing-xs) var(--spacing-lg);
    margin-top: var(--spacing-sm);
    margin-bottom: 2px;
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .sidebar__nav {
    flex: none;
  }

  .sidebar__list {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .sidebar__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px var(--spacing-lg);
    font-size: var(--font-size-base);
    color: var(--text-secondary);
    border-left: 3px solid transparent;
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast);
    cursor: pointer;
    text-decoration: none;
  }

  .sidebar__item:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }

  .sidebar__item--active {
    background: var(--accent-subtle);
    color: var(--accent);
    border-left-color: var(--accent);
    font-weight: 500;
  }

  .sidebar__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .sidebar__item--active .sidebar__icon {
    opacity: 1;
    color: var(--accent);
  }

  .sidebar__label {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sidebar__badge {
    font-size: var(--font-size-xs);
    font-weight: 600;
    background: var(--badge-bg);
    color: var(--badge-text);
    padding: 1px 6px;
    border-radius: 10px;
    min-width: 18px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 105;
      transform: translateX(-100%);
      transition: transform var(--transition-normal);
      box-shadow: var(--shadow-md);
      width: 240px;
      min-width: 240px;
      height: auto;
      background: var(--bg-mobile-sidebar);
    }

    .sidebar:global(.sidebar--open) {
      transform: translateX(0);
    }

    .sidebar__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--spacing-md) var(--spacing-lg);
      min-height: var(--toolbar-height);
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-sidebar-link]").forEach((link) => {
      link.addEventListener("click", () => {
        sessionStorage.removeItem("expanded");
        document.documentElement.removeAttribute("data-expanded");
      });
    });
  });
</script>
