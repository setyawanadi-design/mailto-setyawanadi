      <span class="toolbar__title">mailto:setyawanadi</span>
    </a>
  </div>

  <div class="toolbar__center">
    <div class="toolbar__search">
      <svg
        class="toolbar__search-icon"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        type="text"
        class="toolbar__search-input"
        placeholder="Search (coming soon)"
        aria-label="Search (coming soon)"
        title="Search is coming soon"
        readonly
      />
    </div>
  </div>

  <div class="toolbar__right">
    <button class="toolbar__shortcuts-btn" id="shortcuts-btn" aria-label="Keyboard shortcuts" title="Keyboard shortcuts (?)">
      <span>?</span>
    </button>
    <button class="toolbar__theme-btn" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
      <svg class="theme-icon theme-icon--light" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <svg class="theme-icon theme-icon--dark" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>
  </div>
</header>

<style>
  .toolbar {
    display: flex;
    align-items: center;
    height: var(--toolbar-height);
    min-height: var(--toolbar-height);
    background: var(--bg-toolbar);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border-bottom: 1px solid var(--border-subtle);
    padding: 0 var(--spacing-md);
    gap: var(--spacing-md);
    z-index: 100;
    user-select: none;
  }

  .toolbar__left {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    min-width: var(--sidebar-width);
  }

  .toolbar__menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .toolbar__menu-btn:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }

  .toolbar__brand {
    display: flex;
    align-items: center;
    gap: 2px;
    text-decoration: none;
  }

  .toolbar__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    color: var(--text-primary);
  }

  .toolbar__title {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .toolbar__center {
    flex: 1;
    display: flex;
    justify-content: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .toolbar__search {
    display: flex;
    align-items: center;
    width: 100%;
    height: 30px;
    background: var(--bg-app);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 0 var(--spacing-md);
    gap: var(--spacing-sm);
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .toolbar__search:focus-within {
    border-color: var(--accent-border);
    background: var(--bg-hover);
  }

  .toolbar__search-icon {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .toolbar__search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-family);
    font-size: var(--font-size-sm);
    color: var(--text-primary);
    cursor: not-allowed;
  }

  .toolbar__search-input::placeholder {
    color: var(--text-muted);
  }

  .toolbar__right {
    display: flex;
    align-items: center;
    margin-left: auto;
  }

  .toolbar__shortcuts-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--border-subtle);
    background: var(--bg-action);
    color: var(--text-action);
    cursor: pointer;
    font-size: var(--font-size-sm);
    font-weight: 700;
    font-family: var(--font-family);
    transition: background var(--transition-fast), box-shadow var(--transition-fast);
    box-shadow: var(--shadow-sm);
    margin-right: var(--spacing-xs);
  }

  .toolbar__shortcuts-btn:hover {
    background: var(--bg-action-hover);
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 769px) {
    .toolbar__shortcuts-btn {
      display: flex;
    }
  }

  .toolbar__theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--border-subtle);
    background: var(--bg-action);
    color: var(--text-action);
    cursor: pointer;
    transition: background var(--transition-fast), box-shadow var(--transition-fast);
    box-shadow: var(--shadow-sm);
  }

  .toolbar__theme-btn:hover {
    background: var(--bg-action-hover);
    box-shadow: var(--shadow-md);
  }

  /* Show sun icon when dark, moon icon when light */
  .theme-icon--light {
    display: none;
  }
  .theme-icon--dark {
    display: block;
  }

  :global([data-theme="dark"]) .theme-icon--light {
    display: block;
  }
  :global([data-theme="dark"]) .theme-icon--dark {
    display: none;
  }

  @media (max-width: 768px) {
    .toolbar__menu-btn {
      display: flex;
    }

    .toolbar__left {
      min-width: auto;
    }

    .toolbar__center {
      display: none;
    }
  }
</style>
