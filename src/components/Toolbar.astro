---

---

<header class="toolbar" id="toolbar">
  <div class="toolbar__left">
    <button
      class="toolbar__menu-btn"
      id="menu-toggle"
      aria-label="Toggle sidebar"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <div class="toolbar__brand">
      <svg
        class="toolbar__logo"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
      >
        <rect
          x="2"
          y="4"
          width="20"
          height="16"
          rx="2"
          stroke="currentColor"
          stroke-width="1.5"></rect>
        <path
          d="M2 7l10 6 10-6"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
      </svg>
      <span class="toolbar__title">mailto.setyawanadi</span>
    </div>
  </div>

  <div class="toolbar__center">
    <div class="toolbar__search">
      <svg
        class="toolbar__search-icon"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        type="text"
        class="toolbar__search-input"
        placeholder="Search..."
        aria-label="Search"
        readonly
      />
    </div>
  </div>

  <div class="toolbar__right">
    <div class="toolbar__actions">
      <span class="toolbar__dot"></span>
      <span class="toolbar__dot"></span>
      <span class="toolbar__dot"></span>
    </div>
  </div>
</header>

<style>
  .toolbar {
    display: flex;
    align-items: center;
    height: var(--toolbar-height);
    min-height: var(--toolbar-height);
    background: var(--bg-toolbar);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border-bottom: 1px solid var(--border-subtle);
    padding: 0 var(--spacing-md);
    gap: var(--spacing-md);
    z-index: 100;
    user-select: none;
  }

  .toolbar__left {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    min-width: var(--sidebar-width);
  }

  .toolbar__menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .toolbar__menu-btn:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }

  .toolbar__brand {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .toolbar__logo {
    color: var(--accent);
    flex-shrink: 0;
  }

  .toolbar__title {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .toolbar__center {
    flex: 1;
    display: flex;
    justify-content: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .toolbar__search {
    display: flex;
    align-items: center;
    width: 100%;
    height: 30px;
    background: var(--bg-app);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 0 var(--spacing-md);
    gap: var(--spacing-sm);
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .toolbar__search:focus-within {
    border-color: var(--accent-border);
    background: var(--bg-hover);
  }

  .toolbar__search-icon {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .toolbar__search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-family);
    font-size: var(--font-size-sm);
    color: var(--text-primary);
    cursor: default;
  }

  .toolbar__search-input::placeholder {
    color: var(--text-muted);
  }

  .toolbar__right {
    display: flex;
    align-items: center;
  }

  .toolbar__actions {
    display: flex;
    gap: 4px;
    padding: var(--spacing-sm);
  }

  .toolbar__dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--text-muted);
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .toolbar__menu-btn {
      display: flex;
    }

    .toolbar__left {
      min-width: auto;
    }

    .toolbar__center {
      display: none;
    }
  }
</style>
