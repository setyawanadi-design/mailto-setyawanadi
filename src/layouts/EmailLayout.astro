---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Toolbar from "../components/Toolbar.astro";
import Sidebar from "../components/Sidebar.astro";

interface Props {
  title?: string;
  description?: string;
  currentFolder?: string;
  currentSlug?: string;
  ogImage?: string;
}

const {
  title = "setyawanadi",
  description = "Personal site of Adi Setyawan — designer, developer, and creative thinker.",
  currentFolder = "inbox",
  currentSlug = "",
  ogImage,
} = Astro.props;

const pageTitle = `${currentFolder.charAt(0).toUpperCase() + currentFolder.slice(1)} — ${title}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Adi Setyawan" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <ClientRouter />
    <script is:inline>
      // Apply theme before paint to prevent flash
      (function() {
        var stored = localStorage.getItem('theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();

      // Persist theme across View Transitions (client-side navigation)
      document.addEventListener('astro:before-swap', function(e) {
        var stored = localStorage.getItem('theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          e.newDocument.documentElement.setAttribute('data-theme', 'dark');
        }
      });
    </script>
  </head>
  <body>
    <div class="app-shell" id="app-shell">
      <!-- Top toolbar -->
      <Toolbar />

      <!-- Main content area: sidebar + list + detail -->
      <div class="app-main">
        <!-- Mobile sidebar overlay -->
        <div class="sidebar-overlay" id="sidebar-overlay"></div>

        <!-- Left sidebar -->
        <Sidebar currentFolder={currentFolder} />

        <!-- Content slot (list + detail) -->
        <slot />
      </div>
    </div>

    <!-- Compose Modal -->
    <div class="compose-overlay" id="compose-overlay">
      <div class="compose-modal">
        <div class="compose-modal__header">
          <h3>New Message</h3>
          <button class="compose-modal__close" id="compose-close" aria-label="Close">&times;</button>
        </div>
        <form
          class="compose-modal__form"
          id="compose-form"
          action="https://formspree.io/f/xjgeajby"
          method="POST"
        >
          <input type="hidden" name="_subject" value="New Message from Website" />
          <div class="compose-modal__field">
            <label for="compose-to">To</label>
            <input type="text" id="compose-to" value="setyawanadi" readonly class="compose-modal__input compose-modal__input--readonly" />
          </div>
          <div class="compose-modal__field">
            <label for="compose-from">From</label>
            <input type="email" id="compose-from" name="email" placeholder="your@email.com" required class="compose-modal__input" />
          </div>
          <div class="compose-modal__field">
            <label for="compose-subject">Subject</label>
            <input type="text" id="compose-subject" name="_subject" placeholder="What's this about?" required class="compose-modal__input" />
          </div>
          <div class="compose-modal__field">
            <label for="compose-message">Message</label>
            <textarea id="compose-message" name="message" rows="10" placeholder="Write your message..." required class="compose-modal__textarea"></textarea>
          </div>
          <div class="compose-modal__actions">
            <button type="button" class="compose-modal__cancel" id="compose-cancel">Cancel</button>
            <button type="submit" class="compose-modal__send" id="compose-submit">Send Message</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Compose Success Modal -->
    <div class="compose-overlay" id="compose-success-overlay">
      <div class="compose-modal compose-success-modal">
        <div class="compose-success__content">
          <div class="compose-success__icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <h3 class="compose-success__title">Message Sent!</h3>
          <p class="compose-success__text">Your message has been delivered successfully. Thank you for reaching out!</p>
          <button class="compose-modal__send" id="compose-success-close" style="margin-top: 8px;">Done</button>
        </div>
      </div>
    </div>

    <script>
      // Re-binds on every client-side navigation (View Transitions)
      document.addEventListener("astro:page-load", () => {
        // Theme toggle
        const themeToggle = document.getElementById("theme-toggle");
        themeToggle?.addEventListener("click", () => {
          const isDark = document.documentElement.getAttribute("data-theme") === "dark";
          if (isDark) {
            document.documentElement.removeAttribute("data-theme");
            localStorage.setItem("theme", "light");
          } else {
            document.documentElement.setAttribute("data-theme", "dark");
            localStorage.setItem("theme", "dark");
          }
        });

        const menuBtn = document.getElementById("menu-toggle");
        const sidebar = document.getElementById("sidebar");
        const sidebarOverlay = document.getElementById("sidebar-overlay");

        function toggleSidebar() {
          sidebar?.classList.toggle("sidebar--open");
          sidebarOverlay?.classList.toggle("overlay--visible");
        }

        const sidebarClose = document.getElementById("sidebar-close");

        menuBtn?.addEventListener("click", toggleSidebar);
        sidebarOverlay?.addEventListener("click", toggleSidebar);
        sidebarClose?.addEventListener("click", toggleSidebar);

        // Compose modal
        const composeBtn = document.getElementById("compose-btn");
        const composeOverlay = document.getElementById("compose-overlay");
        const composeClose = document.getElementById("compose-close");
        const composeCancel = document.getElementById("compose-cancel");
        const composeForm = document.getElementById("compose-form") as HTMLFormElement | null;
        const composeSubmit = document.getElementById("compose-submit");

        const composeSuccessOverlay = document.getElementById("compose-success-overlay");
        const composeSuccessClose = document.getElementById("compose-success-close");

        function openCompose() {
          composeOverlay?.classList.add("compose-overlay--visible");
        }
        function closeCompose() {
          composeOverlay?.classList.remove("compose-overlay--visible");
        }
        function openComposeSuccess() {
          composeSuccessOverlay?.classList.add("compose-overlay--visible");
        }
        function closeComposeSuccess() {
          composeSuccessOverlay?.classList.remove("compose-overlay--visible");
        }

        composeBtn?.addEventListener("click", openCompose);
        composeClose?.addEventListener("click", closeCompose);
        composeCancel?.addEventListener("click", closeCompose);
        composeOverlay?.addEventListener("click", (e) => {
          if (e.target === composeOverlay) closeCompose();
        });

        composeSuccessClose?.addEventListener("click", closeComposeSuccess);
        composeSuccessOverlay?.addEventListener("click", (e) => {
          if (e.target === composeSuccessOverlay) closeComposeSuccess();
        });

        composeForm?.addEventListener("submit", async (e) => {
          e.preventDefault();

          if (composeSubmit) {
            composeSubmit.textContent = "Sending...";
            (composeSubmit as HTMLButtonElement).disabled = true;
          }

          const formData = new FormData(composeForm);

          try {
            const response = await fetch(composeForm.action, {
              method: "POST",
              body: formData,
              headers: { Accept: "application/json" },
            });

            if (response.ok) {
              closeCompose();
              openComposeSuccess();
              composeForm.reset();
            } else {
              alert("Failed to send message. Please try again.");
            }
          } catch {
            alert("Network error. Please try again.");
          } finally {
            if (composeSubmit) {
              composeSubmit.textContent = "Send Message";
              (composeSubmit as HTMLButtonElement).disabled = false;
            }
          }
        });
      });
    </script>
  </body>
</html>

<style>
  .app-shell {
    display: flex;
    flex-direction: column;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
  }

  .app-main {
    display: flex;
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .sidebar-overlay {
    display: none;
  }

  /* Compose Modal */
  .compose-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .compose-overlay--visible {
    display: flex;
  }

  .compose-modal {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.16);
    width: 90%;
    max-width: 520px;
    max-height: 90vh;
    overflow-y: auto;
    animation: modalIn 0.2s ease-out;
  }

  @keyframes modalIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  .compose-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-lg) var(--spacing-xl);
    border-bottom: 1px solid #e2e8f0;
  }

  .compose-modal__header h3 {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: #0f172a;
  }

  .compose-modal__close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: #94a3b8;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 8px;
    line-height: 1;
  }

  .compose-modal__close:hover {
    background: #f1f5f9;
    color: #475569;
  }

  .compose-modal__form {
    padding: var(--spacing-lg) var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .compose-modal__field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .compose-modal__field label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .compose-modal__input,
  .compose-modal__textarea {
    padding: var(--spacing-sm) var(--spacing-md);
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: var(--font-size-sm);
    font-family: var(--font-family);
    color: #0f172a;
    transition: border-color var(--transition-fast);
    outline: none;
  }

  .compose-modal__input::placeholder,
  .compose-modal__textarea::placeholder {
    color: #cbd5e1;
  }

  .compose-modal__input:focus,
  .compose-modal__textarea:focus {
    border-color: #93c5fd;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
  }

  .compose-modal__input--readonly {
    background: #f8fafc;
    color: #64748b;
    cursor: not-allowed;
  }

  .compose-modal__textarea {
    resize: vertical;
    min-height: 140px;
  }

  .compose-modal__actions {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: flex-end;
    padding-top: var(--spacing-sm);
  }

  .compose-modal__cancel {
    padding: 8px 16px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    background: #fff;
    color: #64748b;
    font-size: var(--font-size-sm);
    font-weight: 500;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .compose-modal__cancel:hover {
    background: #f1f5f9;
  }

  .compose-modal__send {
    padding: 8px 20px;
    border: 1px solid #1e70bf;
    border-radius: 10px;
    background: linear-gradient(to bottom, #7abcff 0%, #60abf8 44%, #4096ee 100%);
    color: #fff;
    font-size: var(--font-size-sm);
    font-weight: 600;
    cursor: pointer;
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.2);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4), 0 2px 4px rgba(0, 0, 0, 0.15);
    transition: all 0.15s ease;
  }

  .compose-modal__send:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .compose-modal__send:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .compose-success-modal {
    max-width: 380px;
    text-align: center;
  }

  .compose-success__content {
    padding: var(--spacing-2xl) var(--spacing-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  .compose-success__icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #f0fdf4;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: popIn 0.3s ease-out;
  }

  @keyframes popIn {
    from { transform: scale(0.5); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .compose-success__title {
    margin: 0;
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: #0f172a;
  }

  .compose-success__text {
    margin: 0;
    font-size: var(--font-size-sm);
    color: #64748b;
    line-height: 1.5;
  }

  /* ===== DARK MODE ===== */
  :global([data-theme="dark"]) .compose-modal {
    background: #1e293b;
  }

  :global([data-theme="dark"]) .compose-modal__header {
    border-bottom-color: #334155;
  }

  :global([data-theme="dark"]) .compose-modal__header h3 {
    color: #f1f5f9;
  }

  :global([data-theme="dark"]) .compose-modal__close:hover {
    background: #334155;
    color: #e2e8f0;
  }

  :global([data-theme="dark"]) .compose-modal__field label {
    color: #cbd5e1;
  }

  :global([data-theme="dark"]) .compose-modal__input,
  :global([data-theme="dark"]) .compose-modal__textarea {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(148, 163, 184, 0.2);
    color: #f1f5f9;
  }

  :global([data-theme="dark"]) .compose-modal__input--readonly {
    background: rgba(255, 255, 255, 0.03);
    color: #94a3b8;
  }

  :global([data-theme="dark"]) .compose-modal__input::placeholder,
  :global([data-theme="dark"]) .compose-modal__textarea::placeholder {
    color: #64748b;
  }

  :global([data-theme="dark"]) .compose-modal__cancel {
    background: #1e293b;
    border-color: #334155;
    color: #94a3b8;
  }

  :global([data-theme="dark"]) .compose-modal__cancel:hover {
    background: #334155;
  }

  :global([data-theme="dark"]) .compose-success__icon {
    background: #064e3b;
  }

  :global([data-theme="dark"]) .compose-success__title {
    color: #f1f5f9;
  }

  :global([data-theme="dark"]) .compose-success__text {
    color: #94a3b8;
  }

  @media (max-width: 768px) {
    .sidebar-overlay {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 104;
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--transition-normal);
    }

    .sidebar-overlay.overlay--visible {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>
