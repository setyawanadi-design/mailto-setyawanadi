---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Toolbar from "../components/Toolbar.astro";
import Sidebar from "../components/Sidebar.astro";
import FormModal from "../components/FormModal.astro";
import { FORMSPREE_URL } from "../lib/folders";

interface Props {
  title?: string;
  description?: string;
  currentFolder?: string;
  ogImage?: string;
}

const {
  title = "setyawanadi",
  description = "Personal site of Adi Setyawan — designer, developer, and creative thinker.",
  currentFolder = "inbox",
  ogImage,
} = Astro.props;

const pageTitle = currentFolder ? `${title}/${currentFolder}` : title;

// Ensure og:image is always an absolute URL for social scrapers
const absoluteOgImage = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : new URL(ogImage, Astro.site || Astro.url.origin).href
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Adi Setyawan" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    {absoluteOgImage && <meta property="og:image" content={absoluteOgImage} />}
    <meta name="twitter:card" content={absoluteOgImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {absoluteOgImage && <meta name="twitter:image" content={absoluteOgImage} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin.woff2" crossorigin />
    <title>{pageTitle}</title>
    <ClientRouter />
    <script is:inline>
      // Apply theme + expand state before paint to prevent flash
      (function() {
        var stored = localStorage.getItem('theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
        if (sessionStorage.getItem('expanded') === '1') {
          document.documentElement.setAttribute('data-expanded', '');
        }
      })();

      // Register swap handler only once (is:inline re-runs on View Transitions)
      if (!window.__swapRegistered) {
        window.__swapRegistered = true;
        document.addEventListener('astro:before-swap', function(e) {
          window.__astroNav = true;
          // Remove splash from incoming page
          var splash = e.newDocument.getElementById('splash');
          if (splash) splash.remove();
          // Carry theme to new document
          var stored = localStorage.getItem('theme');
          var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          if (theme === 'dark') {
            e.newDocument.documentElement.setAttribute('data-theme', 'dark');
          }
          // Carry expand state to new document
          if (sessionStorage.getItem('expanded') === '1') {
            e.newDocument.documentElement.setAttribute('data-expanded', '');
          }
        });
        // Restore expand state after swap completes (ensures it's applied)
        document.addEventListener('astro:after-swap', function() {
          if (sessionStorage.getItem('expanded') === '1') {
            document.documentElement.setAttribute('data-expanded', '');
          } else {
            document.documentElement.removeAttribute('data-expanded');
          }
        });
      }
    </script>
  </head>
  <body>
    <!-- Loading splash (hard page loads only — skipped during View Transition navigations) -->
    <div class="splash" id="splash" aria-hidden="true">
      <div class="splash__content">
        <span class="splash__logo"><svg width="48" height="48" viewBox="0 0 48 48"><path fill="#45413c" d="M1.18 38.19a22.63 1.66 0 1 0 45.26 0a22.63 1.66 0 1 0-45.26 0" opacity=".15"/><path fill="#fff" d="M2.48 10.94h42.67v26.12H2.48Z"/><path fill="#f0f0f0" d="M44 34.37H3.58a1.1 1.1 0 0 1-1.1-1.1V36a1.1 1.1 0 0 0 1.1 1.1H44a1.1 1.1 0 0 0 1.1-1.1v-2.73a1.1 1.1 0 0 1-1.1 1.1"/><path fill="none" stroke="#45413c" stroke-linecap="round" stroke-linejoin="round" d="M2.48 10.94h42.67v26.12H2.48Z"/><path fill="none" stroke="#45413c" stroke-linecap="round" stroke-linejoin="round" d="m2.79 11.27l21.02 15.58l21.02-15.58M27.7 23.97l17.13 12.7m-42.04 0l17.13-12.7"/><path fill="#00b8f0" d="M14.16 23.75a9.84 9.84 0 1 0 19.68 0a9.84 9.84 0 1 0-19.68 0"/><path fill="#4acfff" d="M24 16.33A9.84 9.84 0 0 1 33.77 25a12 12 0 0 0 .07-1.21a9.84 9.84 0 0 0-19.68 0a12 12 0 0 0 .07 1.21A9.84 9.84 0 0 1 24 16.33"/><path fill="none" stroke="#45413c" stroke-linecap="round" stroke-linejoin="round" d="M14.16 23.75a9.84 9.84 0 1 0 19.68 0a9.84 9.84 0 1 0-19.68 0"/><path fill="#fff" d="M23.83 16.9a7.4 7.4 0 0 1 2.56.45a7.3 7.3 0 0 1 2.2 1.25a6.4 6.4 0 0 1 1.52 1.9a5 5 0 0 1 .58 2.38a4.06 4.06 0 0 1-.57 2.19a4.8 4.8 0 0 1-1.4 1.47a6.7 6.7 0 0 1-1.61.8a4.5 4.5 0 0 1-1.2.24c-.86 0-1.29-.3-1.29-.91a2.4 2.4 0 0 1-.86.66a2.45 2.45 0 0 1-1.09.25a2.3 2.3 0 0 1-1.09-.27a3 3 0 0 1-.88-.74a3.7 3.7 0 0 1-.58-1.05a3.5 3.5 0 0 1-.21-1.18a4.8 4.8 0 0 1 .26-1.54a4.3 4.3 0 0 1 .74-1.34a3.4 3.4 0 0 1 1.09-.92a3.2 3.2 0 0 1 1.48-.35a2.43 2.43 0 0 1 2.18 1.12v-.23c0-.59.34-.89 1-.89a1.25 1.25 0 0 1 .61.14a.42.42 0 0 1 .24.38a3 3 0 0 1-.07.6l-.74 3.38a2.6 2.6 0 0 0-.08.62c0 .26.15.39.43.39a1.37 1.37 0 0 0 .76-.31a2.56 2.56 0 0 0 .78-1a3.4 3.4 0 0 0 .41-1.52a3.8 3.8 0 0 0-.41-1.78a4.1 4.1 0 0 0-1.15-1.37a5.6 5.6 0 0 0-1.66-.86a6.5 6.5 0 0 0-2-.29a5.05 5.05 0 0 0-2 .4a5.1 5.1 0 0 0-1.66 1.1a5.5 5.5 0 0 0-1.11 1.66a5.1 5.1 0 0 0-.41 2a5.3 5.3 0 0 0 .4 2a5.25 5.25 0 0 0 2.78 2.78a5.2 5.2 0 0 0 2 .4a8.14 8.14 0 0 0 3.88-.88a6 6 0 0 0 .56-.43a1.4 1.4 0 0 1 .68-.37a.61.61 0 0 1 .69.69a1 1 0 0 1-.12.46a3.5 3.5 0 0 1-.38.55a5.66 5.66 0 0 1-2.35 1.29a11.2 11.2 0 0 1-3 .36a6.7 6.7 0 0 1-3.43-.92a6.86 6.86 0 0 1-2.49-2.5a6.85 6.85 0 0 1 2.49-9.36a6.6 6.6 0 0 1 3.52-.9m-.76 8.78a1.7 1.7 0 0 0 .93-.28a1.9 1.9 0 0 0 .67-.74a2.1 2.1 0 0 0 .24-1a1.72 1.72 0 0 0-.37-1.12a1.29 1.29 0 0 0-1-.46a1.44 1.44 0 0 0-.88.3a2.15 2.15 0 0 0-.64.76a2.06 2.06 0 0 0-.23.93a1.87 1.87 0 0 0 .35 1.12a1.11 1.11 0 0 0 .93.49"/></svg></span>
        <p class="splash__text" id="splash-text">Accessing setyawanadi...</p>
        <div class="splash__progress">
          <div class="splash__progress-bar" id="splash-bar"></div>
        </div>
      </div>
    </div>
    <script is:inline>
      (function() {
        var splash = document.getElementById('splash');
        if (!splash) return;
        // Only show on hard page loads (initial visit or refresh)
        // window.__astroNav is set by astro:before-swap during View Transitions
        if (window.__astroNav) {
          splash.remove();
          return;
        }
        var text = document.getElementById('splash-text');
        var bar = document.getElementById('splash-bar');
        var steps = [
          { msg: 'Accessing setyawanadi...', pct: 30, delay: 600 },
          { msg: 'Authenticating...', pct: 60, delay: 500 },
          { msg: 'Loading inbox...', pct: 90, delay: 400 },
          { msg: 'Done!', pct: 100, delay: 300 }
        ];
        var i = 0;
        bar.style.width = '10%';
        function next() {
          if (i >= steps.length) {
            splash.classList.add('splash--fade');
            setTimeout(function() { splash.remove(); }, 300);
            return;
          }
          var s = steps[i];
          text.textContent = s.msg;
          bar.style.width = s.pct + '%';
          i++;
          setTimeout(next, s.delay);
        }
        setTimeout(next, 400);
      })();
    </script>

    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="app-shell" id="app-shell">
      <!-- Top toolbar -->
      <Toolbar />

      <!-- Main content area: sidebar + list + detail -->
      <div class="app-main">
        <!-- Mobile sidebar overlay -->
        <div class="sidebar-overlay" id="sidebar-overlay"></div>

        <!-- Left sidebar -->
        <Sidebar currentFolder={currentFolder} />

        <!-- Content slot (list + detail) -->
        <main id="main-content">
          <slot />
        </main>
      </div>
    </div>

    <!-- Compose Modal -->
    <FormModal
      id="compose"
      title="New Message"
      formAction={FORMSPREE_URL}
      showToField={true}
      textareaRows={10}
      submitLabel="Send Message"
    />

    <!-- Keyboard Shortcuts Cheat Sheet -->
    <div class="shortcuts-overlay" id="shortcuts-overlay">
      <div class="shortcuts-modal" role="dialog" aria-modal="true" aria-labelledby="shortcuts-title">
        <div class="shortcuts-modal__header">
          <h3 id="shortcuts-title">Keyboard Shortcuts</h3>
          <button class="shortcuts-modal__close" id="shortcuts-close" aria-label="Close">&times;</button>
        </div>
        <div class="shortcuts-modal__body">
          <div class="shortcuts-group">
            <h4>Navigation</h4>
            <div class="shortcut-row"><kbd>J</kbd><span>Next message</span></div>
            <div class="shortcut-row"><kbd>K</kbd><span>Previous message</span></div>
            <div class="shortcut-row"><kbd>U</kbd><span>Back to list</span></div>
          </div>
          <div class="shortcuts-group">
            <h4>Actions</h4>
            <div class="shortcut-row"><kbd>R</kbd><span>Reply</span></div>
            <div class="shortcut-row"><kbd>C</kbd><span>Compose</span></div>
            <div class="shortcut-row"><kbd>E</kbd><span>Expand / Collapse</span></div>
            <div class="shortcut-row"><kbd>F</kbd><span>Forward / Share</span></div>
          </div>
          <div class="shortcuts-group">
            <h4>General</h4>
            <div class="shortcut-row"><kbd>?</kbd><span>Show shortcuts</span></div>
            <div class="shortcut-row"><kbd>D</kbd><span>Toggle dark mode</span></div>
            <div class="shortcut-row"><kbd>Esc</kbd><span>Close overlay</span></div>
          </div>
        </div>
      </div>
    </div>

    <script>
      // Element click handlers — re-bind on each navigation since DOM elements get replaced
      document.addEventListener("astro:page-load", () => {
        const themeToggle = document.getElementById("theme-toggle");
        themeToggle?.addEventListener("click", () => {
          const isDark = document.documentElement.getAttribute("data-theme") === "dark";
          if (isDark) {
            document.documentElement.removeAttribute("data-theme");
            localStorage.setItem("theme", "light");
          } else {
            document.documentElement.setAttribute("data-theme", "dark");
            localStorage.setItem("theme", "dark");
          }
        });

        const menuBtn = document.getElementById("menu-toggle");
        const sidebar = document.getElementById("sidebar");
        const sidebarOverlay = document.getElementById("sidebar-overlay");

        function toggleSidebar() {
          sidebar?.classList.toggle("sidebar--open");
          sidebarOverlay?.classList.toggle("overlay--visible");
        }

        const sidebarClose = document.getElementById("sidebar-close");

        menuBtn?.addEventListener("click", toggleSidebar);
        sidebarOverlay?.addEventListener("click", toggleSidebar);
        sidebarClose?.addEventListener("click", toggleSidebar);

        const composeBtn = document.getElementById("compose-btn");
        composeBtn?.addEventListener("click", () => {
          document.dispatchEvent(new CustomEvent('form-modal:open:compose'));
        });

        const shortcutsBtn = document.getElementById("shortcuts-btn");
        const shortcutsClose = document.getElementById("shortcuts-close");
        const shortcutsOverlay = document.getElementById("shortcuts-overlay");

        shortcutsBtn?.addEventListener("click", () => {
          shortcutsOverlay?.classList.add("shortcuts-overlay--visible");
        });
        shortcutsClose?.addEventListener("click", () => {
          shortcutsOverlay?.classList.remove("shortcuts-overlay--visible");
        });
        shortcutsOverlay?.addEventListener("click", (e) => {
          if (e.target === shortcutsOverlay) shortcutsOverlay.classList.remove("shortcuts-overlay--visible");
        });
      });

      // Keyboard shortcuts — register ONCE on document (persists across View Transitions)
      document.addEventListener("keydown", (e) => {
        const tag = (e.target as HTMLElement).tagName;
        if (tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT") return;
        if (document.querySelector(".form-modal__overlay--visible")) return;
        if (e.ctrlKey || e.metaKey || e.altKey) return;

        const key = e.key.toLowerCase();
        const shortcutsOverlay = document.getElementById("shortcuts-overlay");

        if (key === "escape") {
          shortcutsOverlay?.classList.remove("shortcuts-overlay--visible");
          return;
        }

        if (key === "?") {
          e.preventDefault();
          shortcutsOverlay?.classList.toggle("shortcuts-overlay--visible");
          return;
        }

        if (shortcutsOverlay?.classList.contains("shortcuts-overlay--visible")) return;

        switch (key) {
          case "j": {
            const nextBtn = document.querySelector('.action-btn--nav[aria-label="Next"]') as HTMLAnchorElement;
            if (nextBtn?.getAttribute("aria-disabled") !== "true") nextBtn?.click();
            break;
          }
          case "k": {
            const prevBtn = document.querySelector('.action-btn--nav[aria-label="Previous"]') as HTMLAnchorElement;
            if (prevBtn?.getAttribute("aria-disabled") !== "true") prevBtn?.click();
            break;
          }
          case "u": {
            const backBtn = document.querySelector(".action-btn--back") as HTMLAnchorElement;
            if (backBtn) {
              backBtn.click();
            } else {
              const activeItem = document.querySelector(".sidebar__item--active") as HTMLAnchorElement;
              if (activeItem) window.location.href = activeItem.href;
            }
            break;
          }
          case "r": {
            const replyBtn = document.getElementById("reply-btn");
            if (replyBtn) {
              e.preventDefault();
              replyBtn.click();
            }
            break;
          }
          case "c": {
            e.preventDefault();
            document.dispatchEvent(new CustomEvent('form-modal:open:compose'));
            break;
          }
          case "e": {
            const expandBtn = document.getElementById("expand-btn");
            expandBtn?.click();
            break;
          }
          case "f": {
            const fwdBtn = document.querySelector(".forward-btn") as HTMLElement;
            fwdBtn?.click();
            break;
          }
          case "d": {
            document.getElementById("theme-toggle")?.click();
            break;
          }
        }
      });
    </script>
  </body>
</html>

<style>
  /* ===== LOADING SPLASH ===== */
  .splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg-detail);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .splash--fade {
    opacity: 0;
    pointer-events: none;
  }

  .splash__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg);
    text-align: center;
  }

  .splash__logo {
    display: flex;
    align-items: center;
    color: var(--text-primary);
    animation: splashPulse 1.5s ease-in-out infinite;
  }

  @keyframes splashPulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.05); }
  }

  .splash__text {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
    font-weight: 500;
    min-width: 200px;
  }

  .splash__progress {
    width: 200px;
    height: 3px;
    background: var(--border-detail);
    border-radius: 999px;
    overflow: hidden;
  }

  .splash__progress-bar {
    height: 100%;
    width: 0%;
    background: var(--text-action);
    border-radius: 999px;
    transition: width 0.4s ease;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--spacing-md);
    z-index: 200;
    padding: var(--spacing-sm) var(--spacing-lg);
    background: var(--accent);
    color: #fff;
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-decoration: none;
  }

  .skip-link:focus {
    top: var(--spacing-sm);
  }

  #main-content {
    display: contents;
  }

  .app-shell {
    display: flex;
    flex-direction: column;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
  }

  .app-main {
    display: flex;
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .sidebar-overlay {
    display: none;
  }

  /* ===== SHORTCUTS MODAL ===== */
  .shortcuts-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .shortcuts-overlay--visible {
    display: flex;
  }

  .shortcuts-modal {
    background: var(--bg-detail);
    border-radius: 16px;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.16);
    width: 90%;
    max-width: 420px;
    animation: shortcutsIn 0.2s ease-out;
  }

  @keyframes shortcutsIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .shortcuts-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-lg) var(--spacing-xl);
    border-bottom: 1px solid var(--border-detail);
  }

  .shortcuts-modal__header h3 {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--text-primary);
  }

  .shortcuts-modal__close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 8px;
    line-height: 1;
  }

  .shortcuts-modal__close:hover {
    background: var(--bg-hover);
    color: var(--text-secondary);
  }

  .shortcuts-modal__body {
    padding: var(--spacing-lg) var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .shortcuts-group h4 {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-sm);
  }

  .shortcut-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 0;
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
  }

  .shortcut-row kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    padding: 0 8px;
    background: var(--bg-code);
    border: 1px solid var(--border-detail);
    border-radius: var(--radius-sm);
    font-family: var(--font-family);
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--text-primary);
    box-shadow: 0 1px 0 var(--border-detail);
  }

  @media (max-width: 768px) {
    .sidebar-overlay {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 104;
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--transition-normal);
    }

    .sidebar-overlay.overlay--visible {
      opacity: 1;
      pointer-events: auto;
    }
  }

  /* Expanded mode: hide message list */
  html[data-expanded] .msg-list {
    display: none;
  }

  html[data-expanded] .reading-pane {
    width: 100%;
    flex: 1;
  }
</style>
