---
import EmailLayout from "../layouts/EmailLayout.astro";
---

<EmailLayout
  title="setyawanadi"
  currentFolder=""
  description="Page not found"
>
  <div class="not-found">
    <div class="not-found__content">
      <span class="not-found__icon">📧</span>
      <h1 class="not-found__title">Message Not Found</h1>
      <p class="not-found__text">
        The message you're looking for doesn't exist or has been moved.
      </p>
      <a href="/inbox" class="not-found__link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Inbox
      </a>
    </div>
  </div>
</EmailLayout>

<style>
  .not-found {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-detail);
  }

  .not-found__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
    text-align: center;
    padding: var(--spacing-xl);
  }

  .not-found__icon {
    font-size: 56px;
    line-height: 1;
    opacity: 0.4;
    margin-bottom: var(--spacing-sm);
    display: block;
  }

  .not-found__title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--text-primary);
  }

  .not-found__text {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
    max-width: 300px;
  }

  .not-found__link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-lg);
    border-radius: 999px;
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text-action);
    border: 1px solid var(--border-subtle);
    background: var(--bg-action);
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .not-found__link:hover {
    background: var(--bg-action-hover);
  }
</style>
