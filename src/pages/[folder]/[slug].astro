---
import { getCollection, render } from 'astro:content';
import EmailLayout from '../../layouts/EmailLayout.astro';
import MessageList from '../../components/MessageList.astro';
import ReadingPane from '../../components/ReadingPane.astro';
import { folderMap, sortMessages, getItemsByFolder, generatePreview, folderIcons } from '../../lib/folders';

const { folder, slug } = Astro.params;
const folderInfo = folderMap[folder!];

if (!folderInfo) {
  return Astro.redirect('/inbox');
}

// Get all posts and filter by folder
const allPosts = await getCollection('posts');
const items = getItemsByFolder(allPosts as any, folder!);

// Sort items
const sortedItems = sortMessages(items as any);

// Find selected item and neighbors
const selectedIndex = sortedItems.findIndex((item: any) => item.id === slug);
const selectedItem = sortedItems[selectedIndex];

if (!selectedItem) {
  return Astro.redirect(`/${folder}`);
}

const prevItem = selectedIndex > 0 ? sortedItems[selectedIndex - 1] : null;
const nextItem = selectedIndex < sortedItems.length - 1 ? sortedItems[selectedIndex + 1] : null;
const prevUrl = prevItem ? `/${folder}/${prevItem.id}` : undefined;
const nextUrl = nextItem ? `/${folder}/${nextItem.id}` : undefined;

const { Content } = await render(selectedItem as any);

// Generate static paths for all folder/slug combos
export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const folders = Object.keys(folderMap);
  const paths: { params: { folder: string; slug: string } }[] = [];

  for (const folder of folders) {
    const items = getItemsByFolder(allPosts as any, folder);
    for (const item of items) {
      paths.push({
        params: { folder, slug: item.id },
      });
    }
  }

  return paths;
}
---

<EmailLayout
  title="setyawanadi"
  currentFolder={folder!}
  description={selectedItem.data.title}
  ogImage={selectedItem.data.image || undefined}
>
  <MessageList
    items={sortedItems.map((item: any) => ({
      slug: item.id,
      data: {
        ...item.data,
        preview: generatePreview(item.body),
      },
    }))}
    activeSlug={slug!}
    folderName={folder!}
    folderLabel={folderInfo.label}
    basePath={`/${folder}`}
    emptyIcon={folderIcons[folder!]}
  />

  <ReadingPane
    title={selectedItem.data.title}
    date={selectedItem.data.date}
    attachments={selectedItem.data.attachments}
    prevUrl={prevUrl}
    nextUrl={nextUrl}
    folderUrl={`/${folder}`}
  >
    <Content />
  </ReadingPane>
</EmailLayout>
