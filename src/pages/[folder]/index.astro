---
import { getCollection } from 'astro:content';
import EmailLayout from '../../layouts/EmailLayout.astro';
import MessageList from '../../components/MessageList.astro';
import { folderMap, getItemsByFolder, generatePreview, folderIcons } from '../../lib/folders';

// Get folder from URL
const { folder } = Astro.params;
const folderInfo = folderMap[folder!];

if (!folderInfo) {
  return Astro.redirect('/inbox');
}

// Get all posts and filter by folder
let items: any[] = [];
if (folder !== 'spam' && folder !== 'trash') {
  try {
    const allPosts = await getCollection('posts');
    items = getItemsByFolder(allPosts as any, folder!);
  } catch {
    items = [];
  }
}

export function getStaticPaths() {
  return [
    { params: { folder: 'inbox' } },
    { params: { folder: 'sent' } },
    { params: { folder: 'drafts' } },
    { params: { folder: 'notes' } },
    { params: { folder: 'archive' } },
    { params: { folder: 'starred' } },
    { params: { folder: 'spam' } },
    { params: { folder: 'trash' } },
  ];
}
---

<EmailLayout
  title="setyawanadi"
  currentFolder={folder!}
  description={`${folderInfo.label} — Personal site of Adi Setyawan`}
>
  <MessageList
    items={items.map((item: any) => ({
      slug: item.id,
      data: {
        ...item.data,
        preview: generatePreview(item.body),
      },
    }))}
    folderName={folder!}
    folderLabel={folderInfo.label}
    basePath={`/${folder}`}
    emptyIcon={folderIcons[folder!]}
  />

  <div class="welcome-pane">
    <div class="welcome-pane__content">
      <svg class="welcome-pane__icon" width="48" height="48" viewBox="0 0 24 24" fill="none">
        <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
        <path d="M2 7l10 6 10-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <h2 class="welcome-pane__title">mailto.setyawanadi</h2>
      <p class="welcome-pane__text">Select a message to start reading.</p>
    </div>
  </div>
</EmailLayout>

<script>
  // Note: We don't clear expand state here anymore - it should persist across folder navigation
  // The expand state is only cleared when user explicitly clicks the collapse button
</script>

<style>
  .welcome-pane {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-detail);
  }

  .welcome-pane__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
    padding: var(--spacing-xl);
  }

  .welcome-pane__icon {
    color: var(--border-subtle);
    margin-bottom: 4px;
  }

  .welcome-pane__title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .welcome-pane__text {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .welcome-pane {
      display: none;
    }
  }
</style>
