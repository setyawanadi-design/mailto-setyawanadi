---
import { getCollection } from 'astro:content';
import EmailLayout from '../../layouts/EmailLayout.astro';
import MessageList from '../../components/MessageList.astro';

// Get folder from URL
const { folder } = Astro.params;

// Map folder names to collection names and labels
const folderMap: Record<string, { collection: string; label: string }> = {
  inbox: { collection: 'inbox', label: 'Inbox' },
  sent: { collection: 'sent', label: 'Sent' },
  drafts: { collection: 'drafts', label: 'Drafts' },
  notes: { collection: 'notes', label: 'Notes' },
  archive: { collection: 'archive', label: 'Archive' },
  starred: { collection: 'starred', label: 'Starred' },
};

const folderInfo = folderMap[folder!];

if (!folderInfo) {
  return Astro.redirect('/inbox');
}

// Get collection items — for spam/trash show empty
let items: any[] = [];
if (folder !== 'spam' && folder !== 'trash') {
  try {
    items = await getCollection(folderInfo.collection as any);
  } catch {
    items = [];
  }
}

// Sort: pinned first, then by date desc
const sortedItems = items.sort((a: any, b: any) => {
  if (a.data.pinned && !b.data.pinned) return -1;
  if (!a.data.pinned && b.data.pinned) return 1;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

export function getStaticPaths() {
  return [
    { params: { folder: 'inbox' } },
    { params: { folder: 'sent' } },
    { params: { folder: 'drafts' } },
    { params: { folder: 'notes' } },
    { params: { folder: 'archive' } },
    { params: { folder: 'starred' } },
    { params: { folder: 'spam' } },
    { params: { folder: 'trash' } },
  ];
}
---

<EmailLayout
  title="setyawanadi"
  currentFolder={folder!}
  description={`${folderInfo.label} — Personal site of Adi Setyawan`}
>
  <MessageList
    items={sortedItems.map((item: any) => ({
      slug: item.id,
      data: item.data,
    }))}
    folderName={folder!}
    folderLabel={folderInfo.label}
    basePath={`/${folder}`}
  />

  <div class="welcome-pane">
    <div class="welcome-pane__content">
      <svg class="welcome-pane__icon" width="48" height="48" viewBox="0 0 24 24" fill="none">
        <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
        <path d="M2 7l10 6 10-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <h2 class="welcome-pane__title">mailto.setyawanadi</h2>
      <p class="welcome-pane__text">Select a message to start reading.</p>
    </div>
  </div>
</EmailLayout>

<style>
  .welcome-pane {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-detail);
  }

  .welcome-pane__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
    padding: var(--spacing-xl);
  }

  .welcome-pane__icon {
    color: #bfdbfe;
    margin-bottom: 4px;
  }

  .welcome-pane__title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
  }

  .welcome-pane__text {
    font-size: var(--font-size-sm);
    color: #94a3b8;
  }

  @media (max-width: 768px) {
    .welcome-pane {
      display: none;
    }
  }
</style>
