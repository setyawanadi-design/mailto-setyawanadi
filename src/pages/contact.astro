---
import EmailLayout from "../layouts/EmailLayout.astro";
---

<EmailLayout
  title="setyawanadi"
  currentFolder="contact"
  description="Get in touch with setyawanadi"
>
  <!-- Empty list panel for contact -->
  <section class="contact-list">
    <div class="contact-list__header">
      <h2>New Message</h2>
    </div>
    <div class="contact-list__hint">
      <svg
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        opacity="0.3"
      >
        <path d="M12 20h9"></path>
        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"
        ></path>
      </svg>
      <p>Composing a new message</p>
      <div class="typing-indicator">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  </section>

  <!-- Contact form as reading pane -->
  <article class="contact-pane">
    <div class="contact-pane__header">
      <div class="contact-field">
        <label class="contact-field__label">From:</label>
        <span class="contact-field__value">You &lt;visitor@web&gt;</span>
      </div>
      <div class="contact-field">
        <label class="contact-field__label">To:</label>
        <span class="contact-field__value"
          >setyawanadi &lt;setyawanadi@hotmail.com&gt;</span
        >
      </div>
      <div class="contact-field">
        <label class="contact-field__label">Subject:</label>
        <span class="contact-field__value contact-field__value--muted"
          >Let's connect!</span
        >
      </div>
    </div>

    <div class="contact-pane__body">
      <div class="email-body">
        <p>Hey there! 👋</p>
        <p>
          Thanks for visiting my site. I'd love to hear from you! Here's how you
          can reach me:
        </p>

        <div class="contact-methods">
          <a href="mailto:setyawanadi@hotmail.com" class="contact-card">
            <div class="contact-card__icon">📧</div>
            <div class="contact-card__info">
              <strong>Email</strong>
              <span>setyawanadi@hotmail.com</span>
            </div>
          </a>

          <a
            href="https://setyawanadi.netlify.app"
            class="contact-card"
            target="_blank"
          >
            <div class="contact-card__icon">🌐</div>
            <div class="contact-card__info">
              <strong>Website</strong>
              <span>setyawanadi.netlify.app</span>
            </div>
          </a>
        </div>

        <p style="margin-top: 2em; color: var(--text-secondary);">
          Or just click the email link above — it'll open your email client with
          my address pre-filled. Looking forward to hearing from you!<span class="blink-cursor"></span>
        </p>

        <div class="email-signature">
          <strong>Adi Setyawan</strong><br />
          setyawanadi@hotmail.com<br />
          <a href="https://setyawanadi.netlify.app">setyawanadi.netlify.app</a>
        </div>
      </div>
    </div>
  </article>
</EmailLayout>

<style>
  .contact-list {
    width: var(--list-width);
    min-width: var(--list-width);
    height: 100%;
    background: var(--bg-list);
    border-right: 1px solid var(--border-subtle);
    display: flex;
    flex-direction: column;
  }

  .contact-list__header {
    padding: var(--spacing-md) var(--spacing-lg);
    border-bottom: 1px solid var(--border-subtle);
  }

  .contact-list__header h2 {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text-primary);
  }

  .contact-list__hint {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    color: var(--text-muted);
    font-size: var(--font-size-sm);
  }

  .typing-indicator {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .typing-indicator span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.4;
    animation: typingBounce 1.4s ease-in-out infinite;
  }

  .typing-indicator span:nth-child(2) {
    animation-delay: 0.2s;
  }

  .typing-indicator span:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes typingBounce {
    0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-4px); }
  }

  .blink-cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    background: var(--accent);
    margin-left: 2px;
    vertical-align: text-bottom;
    animation: cursorBlink 1s step-end infinite;
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .contact-pane {
    flex: 1;
    height: 100%;
    background: var(--bg-detail);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .contact-pane__header {
    padding: var(--spacing-lg) var(--spacing-xl);
    border-bottom: 1px solid var(--border-detail);
    background: var(--bg-detail);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .contact-field {
    display: flex;
    gap: var(--spacing-sm);
    font-size: var(--font-size-sm);
    align-items: baseline;
  }

  .contact-field__label {
    color: var(--text-secondary);
    font-weight: 500;
    min-width: 55px;
  }

  .contact-field__value {
    color: var(--text-primary);
  }

  .contact-field__value--muted {
    color: var(--text-muted);
    font-style: italic;
  }

  .contact-pane__body {
    flex: 1;
    overflow-y: auto;
    padding: var(--spacing-xl);
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin: var(--spacing-xl) 0;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg);
    background: var(--accent-subtle);
    border: 1px solid var(--border-detail);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text-primary);
    transition:
      background 200ms ease,
      border-color 200ms ease,
      transform 200ms ease;
  }

  .contact-card:hover {
    background: var(--bg-hover);
    border-color: var(--accent-border);
    transform: translateY(-2px);
  }

  .contact-card__icon {
    font-size: 1.5rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-detail);
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
  }

  .contact-card__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .contact-card__info strong {
    font-size: var(--font-size-md);
    font-weight: 600;
  }

  .contact-card__info span {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .contact-list {
      display: none;
    }

    .contact-pane {
      width: 100%;
    }
  }
</style>
