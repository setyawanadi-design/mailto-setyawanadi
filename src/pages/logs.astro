---
import { getCollection, render } from 'astro:content';
import EmailLayout from '../layouts/EmailLayout.astro';

function getRelativeTime(date: Date): string {
  const now = new Date();
  const diff = now.getTime() - date.getTime();
  const mins = Math.floor(diff / 60000);
  const hours = Math.floor(diff / 3600000);
  const days = Math.floor(diff / 86400000);
  if (mins < 1) return "just now";
  if (mins < 60) return `${mins}m ago`;
  if (hours < 24) return `${hours}h ago`;
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${days}d ago`;
  return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}

const items = await getCollection('logs');

const sortedItems = items.sort((a: any, b: any) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

// Render all items
const renderedItems = await Promise.all(
  sortedItems.map(async (item: any) => {
    const { Content } = await render(item);
    return { item, Content };
  })
);
---

<EmailLayout
  title="setyawanadi"
  currentFolder="logs"
  description="Logs — short thoughts and updates"
>
  <div class="logs-feed">
    <!-- Header -->
    <div class="logs-feed__header">
      <h1 class="logs-feed__title">Logs</h1>
      <p class="logs-feed__subtitle">Short thoughts, updates, and whatever crosses my mind.</p>
    </div>

    <!-- Timeline -->
    <div class="logs-feed__timeline">
      {renderedItems.map(({ item, Content }) => {
        const date = new Date(item.data.date);
        const formattedDate = date.toLocaleDateString('en-US', {
          month: 'short',
          day: 'numeric',
          year: 'numeric',
        });
        const timeAgo = getRelativeTime(date);
        const logUrl = `/logs/${item.id}`;
        const replySubject = `Re: ${logUrl}`;
        const formspreeSubject = `Log Reply: ${logUrl}`;

        return (
          <article class="log-card" id={item.id}>
            <!-- Avatar + meta -->
            <div class="log-card__meta">
              <div class="log-card__avatar">S</div>
              <div class="log-card__info">
                <span class="log-card__author">setyawanadi</span>
                <span class="log-card__date" title={formattedDate}>{timeAgo}</span>
              </div>
            </div>

            <!-- Title (if any) -->
            {item.data.title && (
              <h2 class="log-card__title">{item.data.title}</h2>
            )}

            <!-- Body -->
            <div class="log-card__body email-body">
              <Content />
            </div>

            <!-- Image (if any) -->
            {item.data.image && (
              <div class="log-card__image">
                <img src={item.data.image} alt={item.data.imageAlt || ''} loading="lazy" />
              </div>
            )}

            <!-- Actions -->
            <div class="log-card__actions">
              <button
                class="log-action-btn log-reply-btn"
                data-reply-subject={replySubject}
                data-formspree-subject={formspreeSubject}
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 17 4 12 9 7"></polyline>
                  <path d="M20 18v-2a4 4 0 0 0-4-4H4"></path>
                </svg>
                <span>Reply</span>
              </button>
              <button class="log-action-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="15 17 20 12 15 7"></polyline>
                  <path d="M4 18v-2a4 4 0 0 1 4-4h12"></path>
                </svg>
                <span>Forward</span>
              </button>
            </div>
          </article>
        );
      })}
    </div>

    {renderedItems.length === 0 && (
      <div class="logs-feed__empty">
        <p>No logs yet.</p>
      </div>
    )}
  </div>

  <!-- Reply Modal (shared) -->
  <div class="reply-modal-overlay" id="log-reply-overlay">
    <div class="reply-modal">
      <div class="reply-modal__header">
        <h3>Reply</h3>
        <button class="reply-modal__close" id="log-reply-close" aria-label="Close">&times;</button>
      </div>
      <form
        class="reply-modal__form"
        id="log-reply-form"
        action="https://formspree.io/f/xjgeajby"
        method="POST"
      >
        <input type="hidden" name="_subject" id="log-hidden-subject" value="" />
        <div class="reply-modal__field">
          <label for="log-reply-subject">Subject</label>
          <input type="text" id="log-reply-subject" readonly class="reply-modal__input reply-modal__input--readonly" />
        </div>
        <div class="reply-modal__field">
          <label for="log-reply-email">Your Email</label>
          <input type="email" id="log-reply-email" name="email" placeholder="your@email.com" required class="reply-modal__input" />
        </div>
        <div class="reply-modal__field">
          <label for="log-reply-message">Message</label>
          <textarea id="log-reply-message" name="message" rows="4" placeholder="Write your reply..." required class="reply-modal__textarea"></textarea>
        </div>
        <div class="reply-modal__actions">
          <button type="button" class="reply-modal__cancel" id="log-reply-cancel">Cancel</button>
          <button type="submit" class="reply-modal__send" id="log-reply-submit">Send Reply</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Success Modal -->
  <div class="reply-modal-overlay" id="log-success-overlay">
    <div class="reply-modal success-modal">
      <div class="success-modal__content">
        <div class="success-modal__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
        </div>
        <h3 class="success-modal__title">Message Sent!</h3>
        <p class="success-modal__text">Your reply has been delivered successfully. Thank you!</p>
        <button class="reply-modal__send" id="log-success-close" style="margin-top: 8px;">Done</button>
      </div>
    </div>
  </div>
</EmailLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const overlay = document.getElementById("log-reply-overlay");
    const closeBtn = document.getElementById("log-reply-close");
    const cancelBtn = document.getElementById("log-reply-cancel");
    const form = document.getElementById("log-reply-form") as HTMLFormElement | null;
    const submitBtn = document.getElementById("log-reply-submit");
    const subjectInput = document.getElementById("log-reply-subject") as HTMLInputElement | null;
    const hiddenSubject = document.getElementById("log-hidden-subject") as HTMLInputElement | null;
    const successOverlay = document.getElementById("log-success-overlay");
    const successClose = document.getElementById("log-success-close");

    function openReply() { overlay?.classList.add("reply-modal-overlay--visible"); }
    function closeReply() { overlay?.classList.remove("reply-modal-overlay--visible"); }
    function openSuccess() { successOverlay?.classList.add("reply-modal-overlay--visible"); }
    function closeSuccess() { successOverlay?.classList.remove("reply-modal-overlay--visible"); }

    // Each reply button sets the subject and opens modal
    document.querySelectorAll(".log-reply-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const replySubject = (btn as HTMLElement).dataset.replySubject || "";
        const formspreeSubject = (btn as HTMLElement).dataset.formspreeSubject || "";
        if (subjectInput) subjectInput.value = replySubject;
        if (hiddenSubject) hiddenSubject.value = formspreeSubject;
        openReply();
      });
    });

    closeBtn?.addEventListener("click", closeReply);
    cancelBtn?.addEventListener("click", closeReply);
    overlay?.addEventListener("click", (e) => { if (e.target === overlay) closeReply(); });
    successClose?.addEventListener("click", closeSuccess);
    successOverlay?.addEventListener("click", (e) => { if (e.target === successOverlay) closeSuccess(); });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (submitBtn) {
        submitBtn.textContent = "Sending...";
        (submitBtn as HTMLButtonElement).disabled = true;
      }
      const formData = new FormData(form);
      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: formData,
          headers: { Accept: "application/json" },
        });
        if (response.ok) {
          form.reset();
          closeReply();
          openSuccess();
        } else {
          alert("Something went wrong. Please try again.");
        }
      } catch {
        alert("Network error. Please check your connection and try again.");
      } finally {
        if (submitBtn) {
          submitBtn.textContent = "Send Reply";
          (submitBtn as HTMLButtonElement).disabled = false;
        }
      }
    });
  });
</script>

<style is:global>
  /* ===== LOG CARD email-body overrides ===== */
  .log-card__body.email-body {
    font-size: var(--font-size-base);
  }

  .log-card__body.email-body p {
    margin: 0;
  }

  .log-card__body.email-body ol {
    margin: 0.5em 0;
    padding-left: 1.5em;
  }
</style>

<style>
  .logs-feed {
    flex: 1;
    height: 100%;
    overflow-y: auto;
    background: var(--bg-detail);
  }

  .logs-feed__header {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--spacing-2xl) var(--spacing-lg) var(--spacing-lg);
  }

  .logs-feed__title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 4px;
  }

  .logs-feed__subtitle {
    font-size: var(--font-size-sm);
    color: #64748b;
    margin: 0;
  }

  .logs-feed__timeline {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg) var(--spacing-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .logs-feed__empty {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--spacing-2xl);
    text-align: center;
    color: #94a3b8;
  }

  /* ===== LOG CARD ===== */
  .log-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: var(--spacing-lg);
    transition: box-shadow var(--transition-fast);
  }

  .log-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .log-card__meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }

  .log-card__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #e0f2fe;
    color: #0ea5e9;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--font-size-sm);
    font-weight: 700;
    flex-shrink: 0;
  }

  .log-card__info {
    display: flex;
    flex-direction: column;
  }

  .log-card__author {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: #0f172a;
    line-height: 1.2;
  }

  .log-card__date {
    font-size: var(--font-size-xs);
    color: #94a3b8;
  }

  .log-card__title {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: #0f172a;
    margin: var(--spacing-xs) 0 var(--spacing-sm);
  }

  .log-card__body {
    color: #334155;
    line-height: 1.6;
    font-size: var(--font-size-base);
  }

  .log-card__image {
    margin-top: var(--spacing-md);
    border-radius: 12px;
    overflow: hidden;
  }

  .log-card__image img {
    width: 100%;
    display: block;
    border-radius: 12px;
  }

  .log-card__actions {
    display: flex;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
    padding-top: var(--spacing-sm);
    border-top: 1px solid #f1f5f9;
  }

  .log-action-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: var(--font-size-xs);
    color: #64748b;
    font-weight: 500;
    border: 1px solid #e2e8f0;
    background: #fff;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .log-action-btn:hover {
    color: #2563eb;
    border-color: #bfdbfe;
    background: #eff6ff;
  }

  /* ===== REPLY/SUCCESS MODAL (same styles as ReadingPane) ===== */
  .reply-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .reply-modal-overlay--visible {
    display: flex;
  }

  .reply-modal {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.16);
    width: 90%;
    max-width: 480px;
    overflow: hidden;
    animation: modalIn 0.2s ease-out;
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .reply-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-lg) var(--spacing-xl);
    border-bottom: 1px solid #e2e8f0;
  }

  .reply-modal__header h3 {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: #0f172a;
  }

  .reply-modal__close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: #94a3b8;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 8px;
    line-height: 1;
  }

  .reply-modal__close:hover {
    background: #f1f5f9;
    color: #475569;
  }

  .reply-modal__form {
    padding: var(--spacing-lg) var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .reply-modal__field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .reply-modal__field label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .reply-modal__input,
  .reply-modal__textarea {
    padding: var(--spacing-sm) var(--spacing-md);
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: var(--font-size-sm);
    font-family: var(--font-family);
    color: #0f172a;
    transition: border-color var(--transition-fast);
    outline: none;
  }

  .reply-modal__input:focus,
  .reply-modal__textarea:focus {
    border-color: #93c5fd;
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
  }

  .reply-modal__input--readonly {
    background: #f8fafc;
    color: #64748b;
    cursor: not-allowed;
  }

  .reply-modal__textarea {
    resize: vertical;
    min-height: 80px;
  }

  .reply-modal__actions {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: flex-end;
    padding-top: var(--spacing-sm);
  }

  .reply-modal__cancel {
    padding: 8px 16px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    background: #fff;
    color: #64748b;
    font-size: var(--font-size-sm);
    font-weight: 500;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .reply-modal__cancel:hover {
    background: #f1f5f9;
  }

  .reply-modal__send {
    padding: 8px 20px;
    border: 1px solid #1e70bf;
    border-radius: 10px;
    background: linear-gradient(to bottom, #7abcff 0%, #60abf8 44%, #4096ee 100%);
    color: #fff;
    font-size: var(--font-size-sm);
    font-weight: 600;
    cursor: pointer;
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.2);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4), 0 2px 4px rgba(0, 0, 0, 0.15);
    transition: all 0.15s ease;
  }

  .reply-modal__send:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .success-modal {
    text-align: center;
    max-width: 380px;
  }

  .success-modal__content {
    padding: var(--spacing-2xl) var(--spacing-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  .success-modal__icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #f0fdf4;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: popIn 0.3s ease-out;
  }

  @keyframes popIn {
    from { transform: scale(0.5); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .success-modal__title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: #0f172a;
    margin: 0;
  }

  .success-modal__text {
    font-size: var(--font-size-sm);
    color: #64748b;
    line-height: 1.5;
    margin: 0;
  }
</style>
