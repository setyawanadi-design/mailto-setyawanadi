---
import { getCollection, render } from 'astro:content';
import EmailLayout from '../../layouts/EmailLayout.astro';

export async function getStaticPaths() {
  const logs = await getCollection('logs');
  return logs.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const title = item.data.title || 'Log';
const date = new Date(item.data.date);
const formattedDate = date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

// Build a plain-text snippet for OG description (strip markdown)
const rawBody = item.body || '';
const snippet = rawBody.replace(/[#*_`\[\]()>-]/g, '').trim().slice(0, 160);
const description = snippet || title;
---

<EmailLayout
  title="setyawanadi"
  currentFolder="logs"
  description={description}
  ogImage={item.data.image || undefined}
>
  <div class="log-single">
    <article class="log-single__card">
      <span class="log-single__date">{formattedDate}</span>
      {title && <h1 class="log-single__title">{title}</h1>}

      <div class="log-single__body email-body">
        <Content />
      </div>

      {item.data.image && (
        <div class="log-single__image">
          <img src={item.data.image} alt={item.data.imageAlt || ''} loading="lazy" />
        </div>
      )}
    </article>

    <a class="log-single__back" href="/logs">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
      Back to all logs
    </a>
  </div>
</EmailLayout>

<style>
  .log-single {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--spacing-2xl) var(--spacing-lg);
  }

  .log-single__card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: var(--spacing-lg);
  }

  .log-single__date {
    font-size: var(--font-size-xs);
    color: #94a3b8;
    display: block;
  }

  .log-single__title {
    font-size: var(--font-size-2xl);
    font-weight: 600;
    color: #0f172a;
    margin: 0 0 var(--spacing-sm);
  }

  .log-single__body {
    color: #334155;
    line-height: 1.6;
    font-size: var(--font-size-base);
  }

  .log-single__image {
    margin-top: var(--spacing-md);
    border-radius: 12px;
    overflow: hidden;
  }

  .log-single__image img {
    width: 100%;
    display: block;
    border-radius: 12px;
  }

  .log-single__back {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-lg);
    font-size: var(--font-size-sm);
    color: #64748b;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .log-single__back:hover {
    color: #0f172a;
  }

  /* ===== DARK MODE ===== */
  :global([data-theme="dark"]) .log-single__card {
    background: #1e293b;
    border-color: rgba(51, 65, 85, 0.4);
  }

  :global([data-theme="dark"]) .log-single__date {
    color: #64748b;
  }

  :global([data-theme="dark"]) .log-single__title {
    color: #f1f5f9;
  }

  :global([data-theme="dark"]) .log-single__body {
    color: #cbd5e1;
  }

  :global([data-theme="dark"]) .log-single__back {
    color: #94a3b8;
  }

  :global([data-theme="dark"]) .log-single__back:hover {
    color: #f1f5f9;
  }
</style>
