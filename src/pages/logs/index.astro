---
import { getCollection, render } from 'astro:content';
import EmailLayout from '../../layouts/EmailLayout.astro';
import FormModal from '../../components/FormModal.astro';
import { FORMSPREE_URL } from '../../lib/folders';

const items = await getCollection('logs');

const sortedItems = items.sort((a: any, b: any) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

// Render all items
const renderedItems = await Promise.all(
  sortedItems.map(async (item: any) => {
    const { Content } = await render(item);
    return { item, Content };
  })
);
---

<EmailLayout
  title="setyawanadi"
  currentFolder="logs"
  description="Logs — short thoughts and updates"
>
  <div class="logs-feed">
    <!-- Header -->
    <div class="logs-feed__header">
      <h1 class="logs-feed__title">Logs</h1>
      <p class="logs-feed__subtitle">Short thoughts, updates, and whatever crosses my mind.</p>
    </div>

    <hr class="logs-feed__divider" />

    <!-- Timeline -->
    <div class="logs-feed__timeline">
      {renderedItems.map(({ item, Content }, index) => {
        const date = new Date(item.data.date);
        const now = new Date();
        const diffMs = now.getTime() - date.getTime();
        const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
        let relativeDate: string;
        if (diffDays === 0) relativeDate = 'today';
        else if (diffDays === 1) relativeDate = 'yesterday';
        else if (diffDays < 30) relativeDate = `${diffDays} days ago`;
        else if (diffDays < 365) {
          const months = Math.floor(diffDays / 30);
          relativeDate = months === 1 ? '1 month ago' : `${months} months ago`;
        } else {
          const years = Math.floor(diffDays / 365);
          relativeDate = years === 1 ? '1 year ago' : `${years} years ago`;
        }
        const formattedDate = date.toLocaleDateString('en-US', {
          month: 'short',
          day: 'numeric',
          year: 'numeric',
        });
        const logUrl = `/logs/${item.id}`;
        const replySubject = `Re: ${logUrl}`;
        const formspreeSubject = `Log Reply: ${logUrl}`;

        return (
          <>
            <article class="log-entry" id={item.id}>
              <span class="log-entry__date" title={formattedDate}>{relativeDate}</span>
              <div class="log-entry__body email-body">
                <Content />
              </div>

              <div class="log-entry__actions">
                <button
                  class="log-action-btn log-reply-btn"
                  data-reply-subject={replySubject}
                  data-formspree-subject={formspreeSubject}
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 17 4 12 9 7"></polyline>
                    <path d="M20 18v-2a4 4 0 0 0-4-4H4"></path>
                  </svg>
                  <span>Reply</span>
                </button>
                <button class="log-action-btn log-forward-btn" data-log-title="" data-log-url={logUrl}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 17 20 12 15 7"></polyline>
                    <path d="M4 18v-2a4 4 0 0 1 4-4h12"></path>
                  </svg>
                  <span>Forward</span>
                </button>
              </div>
            </article>
            {index < renderedItems.length - 1 && <hr class="logs-feed__divider" />}
          </>
        );
      })}
    </div>

    {renderedItems.length === 0 && (
      <div class="logs-feed__empty">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.3">
          <line x1="8" y1="6" x2="21" y2="6"/>
          <line x1="8" y1="12" x2="21" y2="12"/>
          <line x1="8" y1="18" x2="21" y2="18"/>
          <line x1="3" y1="6" x2="3.01" y2="6"/>
          <line x1="3" y1="12" x2="3.01" y2="12"/>
          <line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
        <p>No logs yet.</p>
        <p class="logs-feed__empty-hint">Short thoughts and updates will show up here.</p>
      </div>
    )}
  </div>

  <!-- Image Lightbox -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox__close" id="lightbox-close" aria-label="Close">&times;</button>
    <button class="lightbox__nav lightbox__nav--prev" id="lightbox-prev" aria-label="Previous image">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>
    <img class="lightbox__img" id="lightbox-img" src="" alt="" />
    <button class="lightbox__nav lightbox__nav--next" id="lightbox-next" aria-label="Next image">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 5l7 7-7 7"></path>
      </svg>
    </button>
  </div>

  <!-- Reply Modal (shared) -->
  <FormModal
    id="log-reply"
    title="Reply"
    formAction={FORMSPREE_URL}
    subjectReadonly={true}
    textareaRows={4}
    submitLabel="Send Reply"
    successMessage="Your reply has been delivered successfully. Thank you!"
  />
</EmailLayout>

<script>
  // Reply button handler — delegated click (registered once, persists across navigations)
  if (!(window as any).__logReplyRegistered) {
    (window as any).__logReplyRegistered = true;

    document.addEventListener("click", (e) => {
      const replyBtn = (e.target as HTMLElement).closest(".log-reply-btn");
      if (replyBtn) {
        e.preventDefault();
        e.stopPropagation();
        const replySubject = (replyBtn as HTMLElement).dataset.replySubject || "";
        const formspreeSubject = (replyBtn as HTMLElement).dataset.formspreeSubject || "";
        document.dispatchEvent(new CustomEvent('form-modal:open-with-subject:log-reply', {
          detail: { displaySubject: replySubject, hiddenSubject: formspreeSubject },
        }));
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    // Group consecutive images into photo grids
    document.querySelectorAll(".log-entry__body").forEach((body) => {
      const children = Array.from(body.children);
      let i = 0;
      while (i < children.length) {
        const el = children[i];
        // Check if this is a <p> containing only an <img>
        if (el.tagName === "P" && el.children.length === 1 && el.children[0].tagName === "IMG") {
          // Collect consecutive image paragraphs
          const group: Element[] = [el];
          let j = i + 1;
          while (j < children.length) {
            const next = children[j];
            if (next.tagName === "P" && next.children.length === 1 && next.children[0].tagName === "IMG") {
              group.push(next);
              j++;
            } else {
              break;
            }
          }
          // Wrap in a photo grid
          const grid = document.createElement("div");
          grid.className = "photo-grid";
          grid.setAttribute("data-count", String(group.length));
          el.parentNode!.insertBefore(grid, el);
          group.forEach((p) => {
            const img = p.children[0] as HTMLElement;
            grid.appendChild(img);
            p.remove();
          });
          // Update children array since DOM changed
          i = Array.from(body.children).indexOf(grid) + 1;
          children.splice(0, children.length, ...Array.from(body.children));
        } else {
          i++;
        }
      }
    });

    // Lightbox with prev/next navigation
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
    const lightboxClose = document.getElementById("lightbox-close");
    const lightboxPrev = document.getElementById("lightbox-prev");
    const lightboxNext = document.getElementById("lightbox-next");

    const allImages = Array.from(document.querySelectorAll(".log-entry__body img, .photo-grid img, .log-entry__image img")) as HTMLImageElement[];
    let currentIndex = 0;

    function showImage(index: number) {
      if (!lightboxImg || !allImages.length) return;
      currentIndex = index;
      lightboxImg.src = allImages[currentIndex].src;
      lightboxImg.alt = allImages[currentIndex].alt;
      // Hide arrows at edges
      if (lightboxPrev) lightboxPrev.style.display = currentIndex === 0 ? "none" : "flex";
      if (lightboxNext) lightboxNext.style.display = currentIndex === allImages.length - 1 ? "none" : "flex";
    }

    allImages.forEach((img, i) => {
      img.style.cursor = "pointer";
      img.addEventListener("click", () => {
        if (lightbox) {
          showImage(i);
          lightbox.classList.add("lightbox--visible");
        }
      });
    });

    function closeLightbox() {
      lightbox?.classList.remove("lightbox--visible");
    }

    lightboxPrev?.addEventListener("click", (e) => {
      e.stopPropagation();
      if (currentIndex > 0) showImage(currentIndex - 1);
    });

    lightboxNext?.addEventListener("click", (e) => {
      e.stopPropagation();
      if (currentIndex < allImages.length - 1) showImage(currentIndex + 1);
    });

    lightboxClose?.addEventListener("click", closeLightbox);
    lightbox?.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Lightbox keyboard nav — store handler on window to replace on each page load
    if ((window as any).__lightboxKeydown) {
      document.removeEventListener("keydown", (window as any).__lightboxKeydown);
    }
    (window as any).__lightboxKeydown = (e: KeyboardEvent) => {
      if (!lightbox?.classList.contains("lightbox--visible")) return;
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft" && currentIndex > 0) showImage(currentIndex - 1);
      if (e.key === "ArrowRight" && currentIndex < allImages.length - 1) showImage(currentIndex + 1);
    };
    document.addEventListener("keydown", (window as any).__lightboxKeydown);

    // Forward button — native share sheet on mobile, copy link on desktop
    document.querySelectorAll(".log-forward-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const title = (btn as HTMLElement).dataset.logTitle || '';
        const url = window.location.origin + (btn as HTMLElement).dataset.logUrl;

        if (navigator.share) {
          try {
            await navigator.share({ title, url });
          } catch (err) {
            // User cancelled share — do nothing
          }
        } else {
          // Desktop fallback: copy link to clipboard
          try {
            await navigator.clipboard.writeText(url);
            const label = btn.querySelector("span");
            if (label) {
              const original = label.textContent;
              label.textContent = "Link copied!";
              setTimeout(() => { label.textContent = original; }, 2000);
            }
          } catch {
            // Clipboard API not available
          }
        }
      });
    });

  });
</script>

<style is:global>
  .log-entry__body.email-body {
    font-size: var(--font-size-base);
  }

  .log-entry__body.email-body p {
    margin: 0;
  }

  .log-entry__body.email-body p + p {
    margin-top: var(--spacing-sm);
  }

  .log-entry__body.email-body ol {
    margin: 0.5em 0;
    padding-left: 1.5em;
  }

  .log-entry__body.email-body img {
    width: 100%;
    display: block;
    border-radius: 12px;
    margin-top: var(--spacing-sm);
  }

  /* ===== PHOTO GRID ===== */
  .photo-grid {
    display: grid;
    gap: 4px;
    margin-top: var(--spacing-sm);
    border-radius: 12px;
    overflow: hidden;
  }

  .photo-grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
    margin-top: 0;
  }

  /* 1 image: full width */
  .photo-grid[data-count="1"] {
    grid-template-columns: 1fr;
  }

  .photo-grid[data-count="1"] img {
    max-height: 400px;
  }

  /* 2 images: side by side */
  .photo-grid[data-count="2"] {
    grid-template-columns: 1fr 1fr;
    aspect-ratio: 2 / 1;
  }

  /* 3 images: 1 large left, 2 stacked right */
  .photo-grid[data-count="3"] {
    grid-template-columns: 2fr 1fr;
    grid-template-rows: 1fr 1fr;
    aspect-ratio: 3 / 2;
  }

  .photo-grid[data-count="3"] img:first-child {
    grid-row: 1 / 3;
  }

  /* ===== LIGHTBOX ===== */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    z-index: 2000;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-lg);
  }

  .lightbox--visible {
    display: flex;
  }

  .lightbox__img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    animation: lightboxIn 0.2s ease-out;
  }

  @keyframes lightboxIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  .lightbox__close {
    position: absolute;
    top: var(--spacing-lg);
    right: var(--spacing-lg);
    background: none;
    border: none;
    color: #fff;
    font-size: 2rem;
    cursor: pointer;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.15s ease;
  }

  .lightbox__close:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .lightbox__nav:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  .lightbox__nav--prev {
    left: var(--spacing-lg);
  }

  .lightbox__nav--next {
    right: var(--spacing-lg);
  }
</style>

<style>
  .logs-feed {
    flex: 1;
    height: 100%;
    overflow-y: auto;
    background: var(--bg-detail);
  }

  .logs-feed__header {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--spacing-2xl) var(--spacing-lg) var(--spacing-lg);
  }

  .logs-feed__title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 4px;
  }

  .logs-feed__subtitle {
    font-size: var(--font-size-sm);
    color: var(--text-detail-secondary);
    margin: 0;
  }

  .logs-feed__divider {
    max-width: 600px;
    margin: 0 auto;
    border: none;
    border-top: 1px solid var(--border-detail);
  }

  .logs-feed__timeline {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg) var(--spacing-2xl);
  }

  .logs-feed__empty {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--spacing-2xl) var(--spacing-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    text-align: center;
    color: var(--text-muted);
    font-size: var(--font-size-sm);
  }

  .logs-feed__empty p {
    margin: 0;
  }

  .logs-feed__empty-hint {
    font-size: var(--font-size-xs);
    color: var(--text-detail-secondary);
  }

  /* ===== LOG ENTRY ===== */
  .log-entry {
    padding: var(--spacing-xl) 0;
  }

  .log-entry__date {
    font-size: var(--font-size-xs);
    color: var(--text-muted);
    display: block;
  }

  .log-entry__body {
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: var(--font-size-base);
  }

  .log-entry__actions {
    display: flex;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
  }

  .log-action-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: var(--font-size-xs);
    color: var(--text-detail-secondary);
    font-weight: 500;
    border: 1px solid var(--border-detail);
    background: transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .log-action-btn:hover {
    color: var(--text-action);
    border-color: var(--border-subtle);
    background: var(--bg-action-hover);
  }

</style>
